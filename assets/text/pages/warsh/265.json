[{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"إِذْ دَخَلُواْ عَلَيْهِ فَقَالُواْ سَلَٰماٗۖ قَالَ إِنَّا مِنكُمْ وَجِلُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"قَالُواْ لَا تَوْجَلِ اِنَّا نُبَشِّرُكَ بِغُلَٰمٍ عَلِيمٖۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"قَالَ أَبَشَّرْتُمُونِے عَلَىٰٓ أَن مَّسَّنِيَ اَ۬لْكِبَرُ فَبِمَ تُبَشِّرُونِۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"قَالُواْ بَشَّرْنَٰكَ بِالْحَقِّ فَلَا تَكُن مِّنَ اَ۬لْقَٰنِطِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"قَالَ وَمَنْ يَّقْنَطُ مِن رَّحْمَةِ رَبِّهِۦٓ إِلَّا اَ۬لضَّآلُّونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"قَالَ فَمَا خَطْبُكُمُۥٓ أَيُّهَا اَ۬لْمُرْسَلُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"قَالُوٓاْ إِنَّآ أُرْسِلْنَآ إِلَىٰ قَوْمٖ مُّجْرِمِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"إِلَّآ ءَالَ لُوطٍۖ اِنَّا لَمُنَجُّوهُمُۥٓ أَجْمَعِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"إِلَّا اَ۪مْرَأَتَهُۥ قَدَّرْنَآ إِنَّهَا لَمِنَ اَ۬لْغَٰبِرِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":61,"aya_no_marker":"ﰼ","aya_text":"فَلَمَّا جَآءَ ا۟لَ لُوطٍ اِ۬لْمُرْسَلُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":62,"aya_no_marker":"ﰽ","aya_text":"قَالَ إِنَّكُمْ قَوْمٞ مُّنكَرُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":63,"aya_no_marker":"ﰾ","aya_text":"قَالُواْ بَلْ جِئْنَٰكَ بِمَا كَانُواْ فِيهِ يَمْتَرُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":64,"aya_no_marker":"ﰿ","aya_text":"وَأَتَيْنَٰكَ بِالْحَقِّ وَإِنَّا لَصَٰدِقُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":65,"aya_no_marker":"ﱀ","aya_text":"فَاسْرِ بِأَهْلِكَ بِقِطْعٖ مِّنَ اَ۬ليْلِ وَاتَّبِعَ اَدْبَٰرَهُمْ وَلَا يَلْتَفِتْ مِنكُمُۥٓ أَحَدٞ وَامْضُواْ حَيْثُ تُومَرُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":66,"aya_no_marker":"ﱁ","aya_text":"وَقَضَيْنَآ إِلَيْهِ ذَٰلِكَ اَ۬لَامْرَ أَنَّ دَابِرَ هَٰٓؤُلَآءِ مَقْطُوعٞ مُّصْبِحِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":67,"aya_no_marker":"ﱂ","aya_text":"وَجَآءَ اهْلُ اُ۬لْمَدِينَةِ يَسْتَبْشِرُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":68,"aya_no_marker":"ﱃ","aya_text":"قَالَ إِنَّ هَٰٓؤُلَآءِ ضَيْفِے فَلَا تَفْضَحُونِۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":69,"aya_no_marker":"ﱄ","aya_text":"وَاتَّقُواْ اُ۬للَّهَ وَلَا تُخْزُونِۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":70,"aya_no_marker":"ﱅ","aya_text":"قَالُوٓاْ أَوَلَمْ نَنْهَكَ عَنِ اِ۬لْعَٰلَمِينَۖ"}]