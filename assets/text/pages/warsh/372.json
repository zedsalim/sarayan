[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":112,"aya_no_marker":"ﱯ","aya_text":"قَالَ وَمَا عِلْمِے بِمَا كَانُواْ يَعْمَلُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":113,"aya_no_marker":"ﱰ","aya_text":"إِنْ حِسَابُهُمُۥٓ إِلَّا عَلَىٰ رَبِّے لَوْ تَشْعُرُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":114,"aya_no_marker":"ﱱ","aya_text":"وَمَآ أَنَا بِطَارِدِ اِ۬لْمُومِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":115,"aya_no_marker":"ﱲ","aya_text":"إِنَ اَنَا إِلَّا نَذِيرٞ مُّبِينٞۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":116,"aya_no_marker":"ﱳ","aya_text":"قَالُواْ لَئِن لَّمْ تَنتَهِ يَٰنُوحُ لَتَكُونَنَّ مِنَ اَ۬لْمَرْجُومِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":117,"aya_no_marker":"ﱴ","aya_text":"قَالَ رَبِّ إِنَّ قَوْمِے كَذَّبُونِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":118,"aya_no_marker":"ﱵ","aya_text":"فَافْتَحْ بَيْنِے وَبَيْنَهُمْ فَتْحاٗ وَنَجِّنِے وَمَن مَّعِيَ مِنَ اَ۬لْمُومِنِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":119,"aya_no_marker":"ﱶ","aya_text":"فَأَنجَيْنَٰهُ وَمَن مَّعَهُۥ فِے اِ۬لْفُلْكِ اِ۬لْمَشْحُونِۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":120,"aya_no_marker":"ﱷ","aya_text":"ثُمَّ أَغْرَقْنَا بَعْدُ اُ۬لْبَاقِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":121,"aya_no_marker":"ﱸ","aya_text":"إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":122,"aya_no_marker":"ﱹ","aya_text":"وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":123,"aya_no_marker":"ﱺ","aya_text":"كَذَّبَتْ عَادٌ اِ۬لْمُرْسَلِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":124,"aya_no_marker":"ﱻ","aya_text":"إِذْ قَالَ لَهُمُۥٓ أَخُوهُمْ هُودٌ اَلَا تَتَّقُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_n