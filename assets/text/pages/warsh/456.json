[{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":42,"aya_no_marker":"ﰩ","aya_text":"وَوَهَبْنَا لَهُۥٓ أَهْلَهُۥ وَمِثْلَهُم مَّعَهُمْ رَحْمَةٗ مِّنَّا وَذِكْر۪ىٰ لِأُوْلِے اِ۬لَالْبَٰبِۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":43,"aya_no_marker":"ﰪ","aya_text":"وَخُذْ بِيَدِكَ ضِغْثاٗ فَاضْرِب بِّهِۦ وَلَا تَحْنَثِۖ اِنَّا وَجَدْنَٰهُ صَابِراٗۖ نِّعْمَ اَ۬لْعَبْدُۖ إِنَّهُۥٓ أَوَّابٞۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":44,"aya_no_marker":"ﰫ","aya_text":"وَاذْكُرْ عِبَٰدَنَآ إِبْرَٰهِيمَ وَإِسْحَٰقَ وَيَعْقُوبَ أُوْلِے اِ۬لَايْدِے وَالَابْصٰ۪رِۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"إِنَّآ أَخْلَصْنَٰهُم بِخَالِصَةِ ذِكْرَى اَ۬لدّ۪ارِۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"وَإِنَّهُمْ عِندَنَا لَمِنَ اَ۬لْمُصْطَفَيْنَ اَ۬لَاخْي۪ارِۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":47,"aya_no_marker":"ﰮ","aya_text":"وَاذْكُرِ اِسْمَٰعِيلَ وَالْيَسَعَ وَذَا اَ۬لْكِفْلِۖ وَكُلّٞ مِّنَ اَ۬لَاخْي۪ارِۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"هَٰذَا ذِكْرٞۖ وَإِنَّ لِلْمُتَّقِينَ لَحُسْنَ مَـَٔابٖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"جَنَّٰتِ عَدْنٖ مُّفَتَّحَةٗ لَّهُمُ اُ۬لَابْوَٰبُ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"مُتَّكِـِٕينَ فِيهَا يَدْعُونَ فِيهَا بِفَٰكِهَةٖ كَثِيرَةٖ وَشَرَابٖۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"۞ وَعِندَهُمْ قَٰصِرَٰتُ اُ۬لطَّرْفِ أَتْرَابٌۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"هَٰذَا مَا تُوعَدُونَ لِيَوْمِ اِ۬لْحِسَابِۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"إِنَّ هَٰذَا لَرِزْقُنَا مَا لَهُۥ مِن نَّفَادٍۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"هَٰذَا وَإِنَّ لِلطَّٰغِينَ لَشَرَّ مَـَٔابٖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"جَهَنَّمَ يَصْلَوْنَهَاۖ فَبِيسَ اَ۬لْمِهَادُۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"هَٰذَا فَلْيَذُوقُوهُ حَمِيمٞ وَغَسَاقٞ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"وَءَاخَرُ مِن شَكْلِهِۦٓ أَزْوَٰجٌۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"هَٰذَا فَوْجٞ مُّقْتَحِمٞ مَّعَكُمْۖ لَا مَرْحَباَۢ بِهِمُۥٓۖ إِنَّهُمْ صَالُواْ اُ۬لنّ۪ارِۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"قَالُواْ بَلَ اَنتُمْ لَا مَرْحَباَۢ بِكُمُۥٓ أَنتُمْ قَدَّمْتُمُوهُ لَنَاۖ فَبِيسَ اَ۬لْقَرَارُۖ"},{"jozz":23,"sura_no":38,"sura_name_ar":"صٓ ","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"قَالُواْ رَبَّنَا مَن قَدَّمَ لَنَا هَٰذَا فَزِدْهُ عَذَاباٗ ضِعْفاٗ فِے اِ۬لنّ۪ارِۖ"}]