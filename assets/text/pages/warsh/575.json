[{"jozz":29,"sura_no":73,"sura_name_ar":"المُزمل ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"۞ اِنَّ رَبَّكَ يَعْلَمُ أَنَّكَ تَقُومُ أَدْن۪ىٰ مِن ثُلُثَيِ اِ۬ليْلِ وَنِصْفِهِۦ وَثُلُثِهِۦ وَطَآئِفَةٞ مِّنَ اَ۬لذِينَ مَعَكَۖ وَاللَّهُ يُقَدِّرُ اُ۬ليْلَ وَالنَّهَارَۖ عَلِمَ أَن لَّن تُحْصُوهُ فَتَابَ عَلَيْكُمْۖ فَاقْرَءُواْ مَا تَيَسَّرَ مِنَ اَ۬لْقُرْءَانِۖ عَلِمَ أَن سَيَكُونُ مِنكُم مَّرْض۪ىٰ وَءَاخَرُونَ يَضْرِبُونَ فِے اِ۬لَارْضِ يَبْتَغُونَ مِن فَضْلِ اِ۬للَّهِ وَءَاخَرُونَ يُقَٰتِلُونَ فِے سَبِيلِ اِ۬للَّهِۖ فَاقْرَءُواْ مَا تَيَسَّرَ مِنْهُۖ وَأَقِيمُواْ اُ۬لصَّلَوٰةَ وَءَاتُواْ اُ۬لزَّكَوٰةَۖ وَأَقْرِضُواْ اُ۬للَّهَ قَرْضاً حَسَناٗۖ وَمَا تُقَدِّمُواْ لِأَنفُسِكُم مِّنْ خَيْرٖ تَجِدُوهُ عِندَ اَ۬للَّهِ هُوَ خَيْراٗ وَأَعْظَمَ أَجْراٗۖ وَاسْتَغْفِرُواْ اُ۬للَّهَۖ إِنَّ اَ۬للَّهَ غَفُورٞ رَّحِيمٞۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"يَٰٓأَيُّهَا اَ۬لْمُدَّثِّرُ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"قُمْ فَأَنذِرْۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَرَبَّكَ فَكَبِّرْۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَثِيَابَكَ فَطَهِّرْۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَالرِّجْزَ فَاهْجُرْۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"وَلَا تَمْنُن تَسْتَكْثِرُۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَلِرَبِّكَ فَاصْبِرْۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"فَإِذَا نُقِرَ فِے اِ۬لنَّاقُورِ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"فَذَٰلِكَ يَوْمَئِذٖ يَوْمٌ عَسِيرٌ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"عَلَى اَ۬لْكٰ۪فِرِينَ غَيْرُ يَسِيرٖۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"ذَرْنِے وَمَنْ خَلَقْتُ وَحِيداٗ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"وَجَعَلْتُ لَهُۥ مَالاٗ مَّمْدُوداٗ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"وَبَنِينَ شُهُوداٗ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"وَمَهَّدتُّ لَهُۥ تَمْهِيداٗ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"ثُمَّ يَطْمَعُ أَنَ اَزِيدَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"كَلَّآۖ إِنَّهُۥ كَانَ لِأٓيَٰتِنَا عَنِيداٗۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"سَأُرْهِقُهُۥ صَعُوداًۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"اِنَّهُۥ فَكَّرَ وَقَدَّرَ"}]