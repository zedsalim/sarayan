[{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"فَقُتِلَ كَيْفَ قَدَّرَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"ثُمَّ قُتِلَ كَيْفَ قَدَّرَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"ثُمَّ نَظَرَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"ثُمَّ عَبَسَ وَبَسَرَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"ثُمَّ أَدْبَرَ وَاسْتَكْبَرَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"فَقَالَ إِنْ هَٰذَآ إِلَّا سِحْرٞ يُوثَرُ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"إِنْ هَٰذَآ إِلَّا قَوْلُ اُ۬لْبَشَرِۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"سَأُصْلِيهِ سَقَرَۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"وَمَآ أَدْر۪يٰكَ مَا سَقَرُۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"لَا تُبْقِے وَلَا تَذَرُۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"لَوَّاحَةٞ لِّلْبَشَرِۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"عَلَيْهَا تِسْعَةَ عَشَرَۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":31,"aya_no_marker":"ﰞ","aya_text":"۞ وَمَا جَعَلْنَآ أَصْحَٰبَ اَ۬لنّ۪ارِ إِلَّا مَلَٰٓئِكَةٗۖ وَمَا جَعَلْنَا عِدَّتَهُمُۥٓ إِلَّا فِتْنَةٗ لِّلذِينَ كَفَرُواْ لِيَسْتَيْقِنَ اَ۬لذِينَ أُوتُواْ اُ۬لْكِتَٰبَ وَيَزْدَادَ اَ۬لذِينَ ءَامَنُوٓاْ إِيمَٰناٗ وَلَا يَرْتَابَ اَ۬لذِينَ أُوتُواْ اُ۬لْكِتَٰبَ وَالْمُومِنُونَ وَلِيَقُولَ اَ۬لذِينَ فِے قُلُوبِهِم مَّرَضٞ وَالْكَٰفِرُونَ مَاذَآ أَرَادَ اَ۬للَّهُ بِهَٰذَا مَثَلاٗۖ كَذَٰلِكَ يُضِلُّ اُ۬للَّهُ مَنْ يَّشَآءُ وَيَهْدِے مَنْ يَّشَآءُۖ وَمَا يَعْلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۖ وَمَا هِيَ إِلَّا ذِكْر۪ىٰ لِلْبَشَرِۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":32,"aya_no_marker":"ﰟ","aya_text":"كَلَّا وَالْقَمَرِ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":33,"aya_no_marker":"ﰠ","aya_text":"وَاليْلِ إِذَ اَدْبَرَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":34,"aya_no_marker":"ﰡ","aya_text":"وَالصُّبْحِ إِذَآ أَسْفَرَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":35,"aya_no_marker":"ﰢ","aya_text":"إِنَّهَا لَإِحْدَى اَ۬لْكُبَرِ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":36,"aya_no_marker":"ﰣ","aya_text":"نَذِيراٗ لِّلْبَشَرِ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":37,"aya_no_marker":"ﰤ","aya_text":"لِمَن شَآءَ مِنكُمُۥٓ أَنْ يَّتَقَدَّمَ أَوْ يَتَأَخَّرَۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":38,"aya_no_marker":"ﰥ","aya_text":"كُلُّ نَفْسِۢ بِمَا كَسَبَتْ رَهِينَةٌ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":39,"aya_no_marker":"ﰦ","aya_text":"اِلَّآ أَصْحَٰبَ اَ۬لْيَمِينِۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":40,"aya_no_marker":"ﰧ","aya_text":"فِے جَنَّٰتٖ يَتَسَآءَلُونَ عَنِ اِ۬لْمُجْرِمِينَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":41,"aya_no_marker":"ﰨ","aya_text":"مَا سَلَكَكُمْ فِے سَقَرَۖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":42,"aya_no_marker":"ﰩ","aya_text":"قَالُواْ لَمْ نَكُ مِنَ اَ۬لْمُصَلِّينَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":43,"aya_no_marker":"ﰪ","aya_text":"وَلَمْ نَكُ نُطْعِمُ اُ۬لْمِسْكِينَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":44,"aya_no_marker":"ﰫ","aya_text":"وَكُنَّا نَخُوضُ مَعَ اَ۬لْخَآئِضِينَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"وَكُنَّا نُكَذِّبُ بِيَوْمِ اِ۬لدِّينِ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر ","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"حَتَّىٰٓ أَت۪يٰنَا اَ۬لْيَقِينُۖ"}]