[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":61,"aya_no_marker":"ﰼ","aya_text":"فَلَمَّا تَرَٰٓءَا اَ۬لْجَمْعَٰنِ قَالَ أَصْحَٰبُ مُوس۪ىٰٓ إِنَّا لَمُدْرَكُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":62,"aya_no_marker":"ﰽ","aya_text":"قَالَ كَلَّآۖ إِنَّ مَعِے رَبِّے سَيَهْدِينِۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":63,"aya_no_marker":"ﰾ","aya_text":"فَأَوْحَيْنَآ إِلَىٰ مُوس۪ىٰٓ أَنِ اِ۪ضْرِب بِّعَصَاكَ اَ۬لْبَحْرَ فَانفَلَقَ فَكَانَ كُلُّ فِرْقٖ كَالطَّوْدِ اِ۬لْعَظِيمِۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":64,"aya_no_marker":"ﰿ","aya_text":"وَأَزْلَفْنَا ثَمَّ اَ۬لَاخَرِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":65,"aya_no_marker":"ﱀ","aya_text":"وَأَنجَيْنَا مُوس۪ىٰ وَمَن مَّعَهُۥٓ أَجْمَعِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":66,"aya_no_marker":"ﱁ","aya_text":"ثُمَّ أَغْرَقْنَا اَ۬لَاخَرِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":67,"aya_no_marker":"ﱂ","aya_text":"إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":68,"aya_no_marker":"ﱃ","aya_text":"وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":69,"aya_no_marker":"ﱄ","aya_text":"وَاتْلُ عَلَيْهِمْ نَبَأَ ا۪بْرَٰهِيمَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":70,"aya_no_marker":"ﱅ","aya_text":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا تَعْبُدُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":71,"aya_no_marker":"ﱆ","aya_text":"قَالُواْ نَعْبُدُ أَصْنَاماٗ فَنَظَلُّ لَهَا عَٰكِفِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":72,"aya_no_marker":"ﱇ","aya_text":"قَالَ هَلْ يَسْمَعُونَكُمُۥٓ إِذْ تَدْعُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":73,"aya_no_marker":"ﱈ","aya_text":"أَوْ يَنفَعُونَكُمُۥٓ أَوْ يَضُرُّونَۖ"},{"jozz":19,"sura_no":26,"sura_name_a