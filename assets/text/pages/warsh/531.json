[{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"وَمَآ أَمْرُنَآ إِلَّا وَٰحِدَةٞ كَلَمْحِۢ بِالْبَصَرِۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"وَلَقَدَ اَهْلَكْنَآ أَشْيَاعَكُمْ فَهَلْ مِن مُّدَّكِرٖۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"وَكُلُّ شَےْءٖ فَعَلُوهُ فِے اِ۬لزُّبُرِۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"وَكُلُّ صَغِيرٖ وَكَبِيرٖ مُّسْتَطَرٌۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"اِنَّ اَ۬لْمُتَّقِينَ فِے جَنَّٰتٖ وَنَهَرٖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"فِے مَقْعَدِ صِدْقٍ عِندَ مَلِيكٖ مُّقْتَدِرٍۖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"اِ۬لرَّحْمَٰنُ عَلَّمَ اَ۬لْقُرْءَانَۖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"خَلَقَ اَ۬لِانسَٰنَ عَلَّمَهُ اُ۬لْبَيَانَۖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"اَ۬لشَّمْسُ وَالْقَمَرُ بِحُسْبَانٖۖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَالنَّجْمُ وَالشَّجَرُ يَسْجُدَٰنِۖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَالسَّمَآءَ رَفَعَهَا وَوَضَعَ اَ۬لْمِيزَانَ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"أَلَّا تَطْغَوْاْ فِے اِ۬لْمِيزَانِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَأَقِيمُواْ اُ۬لْوَزْنَ بِالْقِسْطِ وَلَا تُخْسِرُواْ اُ۬لْمِيزَانَۖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"وَالَارْضَ وَضَعَهَا لِلَانَامِ"},{"jozz":27,"sura