[{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك ","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"فَلَمَّا رَأَوْهُ زُلْفَةٗ س۬يَٓٔتْ وُجُوهُ اُ۬لذِينَ كَفَرُواْ وَقِيلَ هَٰذَا اَ۬لذِے كُنتُم بِهِۦ تَدَّعُونَۖ"},{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك ","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"قُلَ اَرَٰٓيْتُمُۥٓ إِنَ اَهْلَكَنِيَ اَ۬للَّهُ وَمَن مَّعِيَ أَوْ رَحِمَنَا فَمَنْ يُّجِيرُ اُ۬لْكٰ۪فِرِينَ مِنْ عَذَابٍ اَلِيمٖۖ"},{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك ","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"قُلْ هُوَ اَ۬لرَّحْمَٰنُ ءَامَنَّا بِهِۦ وَعَلَيْهِ تَوَكَّلْنَاۖ فَسَتَعْلَمُونَ مَنْ هُوَ فِے ضَلَٰلٖ مُّبِينٖۖ"},{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك ","aya_no":31,"aya_no_marker":"ﰞ","aya_text":"قُلَ اَرَٰٓيْتُمُۥٓ إِنَ اَصْبَحَ مَآؤُكُمْ غَوْراٗ فَمَنْ يَّاتِيكُم بِمَآءٖ مَّعِينٖۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"نُّٓۖ وَالْقَلَمِ وَمَا يَسْطُرُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"مَآ أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَإِنَّ لَكَ لَأَجْراً غَيْرَ مَمْنُونٖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٖۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"فَسَتُبْصِرُ وَيُبْصِرُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"بِأَييِّكُمُ اُ۬لْمَفْتُونُۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦۖ وَهُوَ أَعْلَمُ بِالْمُهْتَدِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"فَلَا تُطِعِ اِ۬لْمُكَذِّبِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":9,"aya_no_marker":"ﰈ",