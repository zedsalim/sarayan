[{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِنَّ اَ۬لذِينَ كَفَرُواْ مِنَ اَهْلِ اِ۬لْكِتَٰبِ وَالْمُشْرِكِينَ فِے ن۪ارِ جَهَنَّمَ خَٰلِدِينَ فِيهَآۖ أُوْلَٰٓئِكَ هُمْ شَرُّ اُ۬لْبَرِيَٓٔةِۖ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"إِنَّ اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ أُوْلَٰٓئِكَ هُمْ خَيْرُ اُ۬لْبَرِيَٓٔةِۖ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"جَزَآؤُهُمْ عِندَ رَبِّهِمْ جَنَّٰتُ عَدْنٖ تَجْرِے مِن تَحْتِهَا اَ۬لَانْهَٰرُ خَٰلِدِينَ فِيهَآ أَبَداٗۖ رَّضِيَ اَ۬للَّهُ عَنْهُمْ وَرَضُواْ عَنْهُۖ ذَٰلِكَ لِمَنْ خَشِيَ رَبَّهُۥٓۖ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"إِذَا زُلْزِلَتِ اِ۬لَارْضُ زِلْزَالَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَأَخْرَجَتِ اِ۬لَارْضُ أَثْقَالَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَقَالَ اَ۬لِانسَٰنُ مَا لَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"يَوْمَئِذٖ تُحَدِّثُ أَخْبَارَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"بِأَنَّ رَبَّكَ أَوْح۪ىٰ لَهَاۖ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"يَوْمَئِذٖ يَصْدُرُ اُ۬لنَّاسُ أَشْتَاتاٗ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"لِّيُرَوَاْ اَعْمَٰلَهُمْۖ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"فَمَنْ يَّعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْراٗ يَرَهُۥۖ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَمَنْ يَّعْمَلْ مِثْقَالَ ذَرَّةٖ شَرّاٗ يَرَهُۥۖ"},{"jozz":30,"sura_no":100,"sura_name_ar":"العَاديَ