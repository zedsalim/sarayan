[{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَالصَّٰٓفَّٰتِ صَفّاٗ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"فَالزَّٰجِرَٰتِ زَجْراٗ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"فَالتَّٰلِيَٰتِ ذِكْراً"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"اِنَّ إِلَٰهَكُمْ لَوَٰحِدٞۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"رَّبُّ اُ۬لسَّمَٰوَٰتِ وَالَارْضِ وَمَا بَيْنَهُمَا وَرَبُّ اُ۬لْمَشَٰرِقِۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِنَّا زَيَّنَّا اَ۬لسَّمَآءَ اَ۬لدُّنْي۪ا بِزِينَةِ اِ۬لْكَوَاكِبِۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَحِفْظاٗ مِّن كُلِّ شَيْطَٰنٖ مَّارِدٖۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"لَّا يَسْمَعُونَ إِلَى اَ۬لْمَلَإِ اِ۬لَاعْل۪ىٰ وَيُقْذَفُونَ مِن كُلِّ جَانِبٖۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"دُحُوراٗۖ وَلَهُمْ عَذَابٞ وَاصِبٌ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"اِلَّا مَنْ خَطِفَ اَ۬لْخَطْفَةَ فَأَتْبَعَهُۥ شِهَابٞ ثَاقِبٞۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"فَاسْتَفْتِهِمُۥٓ أَهُمُۥٓ أَشَدُّ خَلْقاً اَم مَّنْ خَلَقْنَآۖ إِنَّا خَلَقْنَٰهُم مِّن طِينٖ لَّٰزِبِۢۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"بَلْ عَجِبْتَ وَيَسْخَرُونَۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"وَإِذَا ذُكِّرُواْ لَا يَذْكُرُونَۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"وَإِذَا رَأَوَاْ اٰيَةٗ يَسْتَسْخِرُونَۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"وَقَالُوٓاْ إِنْ هَٰذَآ إِلَّا سِحْرٞ مُّبِينٌ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"اَ۟ذَا مِتْنَا وَكُنَّا تُرَاباٗ وَعِظَٰماً اِنَّا لَمَبْعُوثُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"أَوَءَابَآؤُنَا اَ۬لَاوَّلُونَۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"قُلْ نَعَمْ وَأَنتُمْ دَٰخِرُونَۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"فَإِنَّمَا هِيَ زَجْرَةٞ وَٰحِدَةٞ فَإِذَا هُمْ يَنظُرُونَۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"وَقَالُواْ يَٰوَيْلَنَا هَٰذَا يَوْمُ اُ۬لدِّينِۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"هَٰذَا يَوْمُ اُ۬لْفَصْلِ اِ۬لذِے كُنتُم بِهِۦ تُكَذِّبُونَۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"۞ اَ۟حْشُرُواْ اُ۬لذِينَ ظَلَمُواْ وَأَزْوَٰجَهُمْ وَمَا كَانُواْ يَعْبُدُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"مِن دُونِ اِ۬للَّهِ فَاهْدُوهُمُۥٓ إِلَىٰ صِرَٰطِ اِ۬لْجَحِيمِۖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات ","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"وَقِفُوهُمُۥٓ إِنَّهُم مَّسْـُٔولُونَۖ"}]