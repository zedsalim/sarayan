[{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":43,"aya_no_marker":"ﰪ","aya_text":"خَٰشِعَةً اَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٞۖ وَقَدْ كَانُواْ يُدْعَوْنَ إِلَى اَ۬لسُّجُودِ وَهُمْ سَٰلِمُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":44,"aya_no_marker":"ﰫ","aya_text":"فَذَرْنِے وَمَنْ يُّكَذِّبُ بِهَٰذَا اَ۬لْحَدِيثِۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"وَأُمْلِے لَهُمُۥٓۖ إِنَّ كَيْدِے مَتِينٌۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"اَمْ تَسْـَٔلُهُمُۥٓ أَجْراٗ فَهُم مِّن مَّغْرَمٖ مُّثْقَلُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":47,"aya_no_marker":"ﰮ","aya_text":"أَمْ عِندَهُمُ اُ۬لْغَيْبُ فَهُمْ يَكْتُبُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"۞ فَاصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَٰحِبِ اِ۬لْحُوتِ إِذْ نَاد۪ىٰ وَهُوَ مَكْظُومٞۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"لَّوْلَآ أَن تَدَٰرَكَهُۥ نِعْمَةٞ مِّن رَّبِّهِۦ لَنُبِذَ بِالْعَرَآءِ وَهُوَ مَذْمُومٞۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"فَاجْتَبٰ۪هُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ اَ۬لصَّٰلِحِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"وَإِنْ يَّكَادُ اُ۬لذِينَ كَفَرُواْ لَيَزْلِقُونَكَ بِأَبْصٰ۪رِهِمْ لَمَّا سَمِعُواْ اُ۬لذِّكْرَ وَيَقُولُونَ إِنَّهُۥ لَمَجْنُونٞۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"وَمَا هُوَ إِلَّا ذِكْرٞ لِّلْعَٰلَمِينَۖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"اَ۬لْحَآقَّةُ مَا اَ۬لْحَآقَّةُۖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَمَآ أَدْر۪يٰكَ مَا اَ۬لْحَآقَّةُۖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"كَذَّبَتْ ثَمُودُ وَعَادُۢ بِالْقَارِعَةِۖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"فَأَمَّا ثَمُودُ فَأُهْلِكُواْ بِالطَّاغِيَةِۖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَأَمَّا عَادٞ فَأُهْلِكُواْ بِرِيحٖ صَرْصَرٍ عَاتِيَةٖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"سَخَّرَهَا عَلَيْهِمْ سَبْعَ لَيَالٖ وَثَمَٰنِيَةَ أَيَّامٍ حُسُوماٗۖ فَتَرَى اَ۬لْقَوْمَ فِيهَا صَرْع۪ىٰ كَأَنَّهُمُۥٓ أَعْجَازُ نَخْلٍ خَاوِيَةٖۖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"فَهَلْ تَر۪ىٰ لَهُم مِّنۢ بَاقِيَةٖۖ"}]