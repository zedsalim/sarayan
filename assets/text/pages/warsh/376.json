[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":207,"aya_no_marker":"ﳎ","aya_text":"مَآ أَغْن۪ىٰ عَنْهُم مَّا كَانُواْ يُمَتَّعُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":208,"aya_no_marker":"ﳏ","aya_text":"وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ اِلَّا لَهَا مُنذِرُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":209,"aya_no_marker":"ﳐ","aya_text":"ذِكْر۪ىٰۖ وَمَا كُنَّا ظَٰلِمِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":210,"aya_no_marker":"ﳑ","aya_text":"۞ وَمَا تَنَزَّلَتْ بِهِ اِ۬لشَّيَٰطِينُ وَمَا يَنۢبَغِے لَهُمْ وَمَا يَسْتَطِيعُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":211,"aya_no_marker":"ﳒ","aya_text":"إِنَّهُمْ عَنِ اِ۬لسَّمْعِ لَمَعْزُولُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":212,"aya_no_marker":"ﳓ","aya_text":"فَلَا تَدْعُ مَعَ اَ۬للَّهِ إِلَٰهاً اٰخَرَ فَتَكُونَ مِنَ اَ۬لْمُعَذَّبِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":213,"aya_no_marker":"ﳔ","aya_text":"وَأَنذِرْ عَشِيرَتَكَ اَ۬لَاقْرَبِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":214,"aya_no_marker":"ﳕ","aya_text":"وَاخْفِضْ جَنَاحَكَ لِمَنِ اِ۪تَّبَعَكَ مِنَ اَ۬لْمُومِنِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":215,"aya_no_marker":"ﳖ","aya_text":"فَإِنْ عَصَوْكَ فَقُلِ اِنِّے بَرِےٓءٞ مِّمَّا تَعْمَلُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":216,"aya_no_marker":"ﳗ","aya_text":"فَتَوَكَّلْ عَلَى اَ۬لْعَزِيزِ اِ۬لرَّحِيمِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":217,"aya_no_marker":"ﳘ","aya_text":"اِ۬لذِے يَر۪يٰكَ حِينَ تَقُومُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":218,"aya_no_marker":"ﳙ","aya_text":"وَتَقَلُّبَكَ فِے اِ۬لسَّٰجِدِينَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":219,"aya_no_marker":"ﳚ","aya_text":"إِنَّهُۥ هُوَ اَ۬لسَّمِيعُ اُ۬لْعَلِيمُۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":220,"aya_no_marker":"ﳛ","aya_text":"هَلُ ا۟نَبِّئُكُمْ عَلَىٰ مَن تَنَزَّلُ اُ۬لشَّيَٰطِينُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":221,"aya_no_marker":"ﳜ","aya_text":"تَنَزَّلُ عَلَىٰ كُلِّ أَفَّاكٍ اَثِيمٖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":222,"aya_no_marker":"ﳝ","aya_text":"يُلْقُونَ اَ۬لسَّمْعَ وَأَكْثَرُهُمْ كَٰذِبُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":223,"aya_no_marker":"ﳞ","aya_text":"وَالشُّعَرَآءُ يَتْبَعُهُمُ اُ۬لْغَاوُۥنَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":224,"aya_no_marker":"ﳟ","aya_text":"أَلَمْ تَرَ أَنَّهُمْ فِے كُلِّ وَادٖ يَهِيمُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":225,"aya_no_marker":"ﳠ","aya_text":"وَأَنَّهُمْ يَقُولُونَ مَا لَا يَفْعَلُونَۖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء ","aya_no":226,"aya_no_marker":"ﳡ","aya_text":"إِلَّا اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ وَذَكَرُواْ اُ۬للَّهَ كَثِيراٗ وَانتَصَرُواْ مِنۢ بَعْدِ مَا ظُلِمُواْۖ وَسَيَعْلَمُ اُ۬لذِينَ ظَلَمُوٓاْ أَيَّ مُنقَلَبٖ يَنقَلِبُونَۖ"}]