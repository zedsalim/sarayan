[{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَالنَّجْمِ إِذَا هَو۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"مَا ضَلَّ صَٰحِبُكُمْ وَمَا غَو۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَمَا يَنطِقُ عَنِ اِ۬لْهَو۪ىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"إِنْ هُوَ إِلَّا وَحْيٞ يُوح۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"عَلَّمَهُۥ شَدِيدُ اُ۬لْقُو۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"ذُو مِرَّةٖۖ فَاسْتَو۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَهُوَ بِالُافُقِ اِ۬لَاعْل۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"ثُمَّ دَنَا فَتَدَلّ۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"فَكَانَ قَابَ قَوْسَيْنِ أَوَ اَدْن۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"فَأَوْح۪ىٰٓ إِلَىٰ عَبْدِهِۦ مَآ أَوْح۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"مَا كَذَبَ اَ۬لْفُؤَادُ مَا ر۪أ۪ىٰٓۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَر۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"وَلَقَدْ ر۪ء۪اهُ نَزْلَةً ا۟خْر۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"عِندَ سِدْرَةِ اِ۬لْمُنتَه۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"عِندَهَا جَنَّةُ اُ۬لْمَأْو۪ىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"إِذْ يَغْشَى اَ۬لسِّدْرَةَ مَا يَغْش۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"مَا زَاغَ اَ۬لْبَصَرُ وَمَا طَغ۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"لَقَدْ ر۪أ۪ىٰ مِنَ اٰيَٰتِ رَبِّهِ اِ۬لْكُبْر۪ىٰٓۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"أَفَرَٰٓيْتُمُ اُ۬للَّٰتَ وَالْعُزّ۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"وَمَنَوٰةَ اَ۬لثَّالِثَةَ اَ۬لُاخْر۪ىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"أَلَكُمُ اُ۬لذَّكَرُ وَلَهُ اُ۬لُانث۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"تِلْكَ إِذاٗ قِسْمَةٞ ضِيز۪ىٰٓۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"إِنْ هِيَ إِلَّآ أَسْمَآءٞ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّآ أَنزَلَ اَ۬للَّهُ بِهَا مِن سُلْطَٰنٍۖ اِنْ يَّتَّبِعُونَ إِلَّا اَ۬لظَّنَّ وَمَا تَهْوَى اَ۬لَانفُسُۖ وَلَقَدْ جَآءَهُم مِّن رَّبِّهِمُ اُ۬لْهُد۪ىٰٓۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"أَمْ لِلِانسَٰنِ مَا تَمَنّ۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"فَلِلهِ اِ۬لَاخِرَةُ وَالُاول۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"۞ وَكَم مِّن مَّلَكٖ فِے اِ۬لسَّمَٰوَٰتِ لَا تُغْنِے شَفَٰعَتُهُمْ شَئْاً اِلَّا مِنۢ بَعْدِ أَنْ يَّاذَنَ اَ۬للَّهُ لِمَنْ يَّشَآءُ وَيَرْض۪ىٰٓۖ"}]