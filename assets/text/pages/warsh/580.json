[{"jozz":29,"sura_no":76,"sura_name_ar":"الإنسَان ","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"وَمِنَ اَ۬ليْلِ فَاسْجُدْ لَهُۥ وَسَبِّحْهُ لَيْلاٗ طَوِيلاًۖ"},{"jozz":29,"sura_no":76,"sura_name_ar":"الإنسَان ","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"اِنَّ هَٰٓؤُلَآءِ يُحِبُّونَ اَ۬لْعَاجِلَةَ وَيَذَرُونَ وَرَآءَهُمْ يَوْماٗ ثَقِيلاٗۖ"},{"jozz":29,"sura_no":76,"sura_name_ar":"الإنسَان ","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"نَّحْنُ خَلَقْنَٰهُمْ وَشَدَدْنَآ أَسْرَهُمْ وَإِذَا شِئْنَا بَدَّلْنَآ أَمْثَٰلَهُمْ تَبْدِيلاًۖ"},{"jozz":29,"sura_no":76,"sura_name_ar":"الإنسَان ","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"اِنَّ هَٰذِهِۦ تَذْكِرَةٞۖ فَمَن شَآءَ اَ۪تَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلاٗۖ"},{"jozz":29,"sura_no":76,"sura_name_ar":"الإنسَان ","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"وَمَا تَشَآءُونَ إِلَّآ أَنْ يَّشَآءَ اَ۬للَّهُۖ إِنَّ اَ۬للَّهَ كَانَ عَلِيماً حَكِيماٗۖ"},{"jozz":29,"sura_no":76,"sura_name_ar":"الإنسَان ","aya_no":31,"aya_no_marker":"ﰞ","aya_text":"يُدْخِلُ مَنْ يَّشَآءُ فِے رَحْمَتِهِۦۖ وَالظَّٰلِمِينَ أَعَدَّ لَهُمْ عَذَاباً اَلِيماٗۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَالْمُرْسَلَٰتِ عُرْفاٗ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"فَالْعَٰصِفَٰتِ عَصْفاٗ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَالنَّٰشِرَٰتِ نَشْراٗ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"فَالْفَٰرِقَٰتِ فَرْقاٗ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"فَالْمُلْقِيَٰتِ ذِكْراً"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"عُذْراً اَوْ نُذُراً"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"اِنَّمَا تُوعَدُونَ لَوَٰقِعٞۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"فَإِذَا اَ۬لنُّجُومُ طُمِسَتْ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَإِذَا اَ۬لسَّمَآءُ فُرِجَتْ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"وَإِذَا اَ۬لْجِبَالُ نُسِفَتْ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"وَإِذَا اَ۬لرُّسُلُ أُقِّتَتْ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"لِأَيِّ يَوْمٍ ا۟جِّلَتْ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"لِيَوْمِ اِ۬لْفَصْلِۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"وَمَآ أَدْر۪يٰكَ مَا يَوْمُ اُ۬لْفَصْلِۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"۞ أَلَمْ نُهْلِكِ اِ۬لَاوَّلِينَۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"ثُمَّ نُتْبِعُهُمُ اُ۬لَاخِرِينَۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"كَذَٰلِكَ نَفْعَلُ بِالْمُجْرِمِينَۖ"},{"jozz":29,"sura_no":77,"sura_name_ar":"المُرسَلات ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ"}]