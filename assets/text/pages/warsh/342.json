[{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"قَدَ اَفْلَحَ اَ۬لْمُومِنُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"اَ۬لذِينَ هُمْ فِے صَلَاتِهِمْ خَٰشِعُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَالذِينَ هُمْ عَنِ اِ۬للَّغْوِ مُعْرِضُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَالذِينَ هُمْ لِلزَّكَوٰةِ فَٰعِلُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَالذِينَ هُمْ لِفُرُوجِهِمْ حَٰفِظُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِلَّا عَلَىٰٓ أَزْوَٰجِهِمُۥٓ أَوْ مَا مَلَكَتَ اَيْمَٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"فَمَنِ اِ۪بْتَغ۪ىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ اُ۬لْعَادُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"وَالذِينَ هُمْ لِأَمَٰنَٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَالذِينَ هُمْ عَلَىٰ صَلَوَٰتِهِمْ يُحَافِظُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"أُوْلَٰٓئِكَ هُمُ اُ۬لْوَٰرِثُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"اَ۬لذِينَ يَرِثُونَ اَ۬لْفِرْدَوْسَۖ هُمْ فِيهَا خَٰلِدُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"وَلَقَدْ خَلَقْنَا اَ۬لِانسَٰنَ مِن سُلَٰلَةٖ مِّن طِينٖۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"ثُمَّ جَعَلْنَٰهُ نُطْفَةٗ فِے قَر۪ارٖ مَّكِينٖۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"ثُمَّ خَلَقْنَا اَ۬لنُّطْفَةَ عَلَقَةٗ فَخَلَقْنَا اَ۬لْعَلَقَةَ مُضْغَةٗ فَخَلَقْنَا اَ۬لْمُضْغَةَ عِظَٰماٗ فَكَسَوْنَا اَ۬لْعِظَٰمَ لَحْماٗ ثُمَّ أَنشَأْنَٰهُ خَلْقاً اٰخَرَۖ فَتَبَٰرَكَ اَ۬للَّهُ أَحْسَنُ اُ۬لْخَٰلِقِينَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"ثُمَّ إِنَّكُم بَعْدَ ذَٰلِكَ لَمَيِّتُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"ثُمَّ إِنَّكُمْ يَوْمَ اَ۬لْقِيَٰمَةِ تُبْعَثُونَۖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"وَلَقَدْ خَلَقْنَا فَوْقَكُمْ سَبْعَ طَرَآئِقَۖ وَمَا كُنَّا عَنِ اِ۬لْخَلْقِ غَٰفِلِينَۖ"}]