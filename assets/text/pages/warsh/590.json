[{"jozz":30,"sura_no":84,"sura_name_ar":"الانشِقَاق ","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"اِلَّا اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ لَهُمُۥٓ أَجْرٌ غَيْرُ مَمْنُونٖۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَالسَّمَآءِ ذَاتِ اِ۬لْبُرُوجِ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَالْيَوْمِ اِ۬لْمَوْعُودِ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَشَاهِدٖ وَمَشْهُودٖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"قُتِلَ أَصْحَٰبُ اُ۬لُاخْدُودِ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"اِ۬لنّ۪ارِ ذَاتِ اِ۬لْوَقُودِ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِذْ هُمْ عَلَيْهَا قُعُودٞ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِالْمُومِنِينَ شُهُودٞۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"وَمَا نَقَمُواْ مِنْهُمُۥٓ إِلَّآ أَنْ يُّومِنُواْ بِاللَّهِ اِ۬لْعَزِيزِ اِ۬لْحَمِيدِ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"اِ۬لذِے لَهُۥ مُلْكُ اُ۬لسَّمَٰوَٰتِ وَالَارْضِۖ وَاللَّهُ عَلَىٰ كُلِّ شَےْءٖ شَهِيدٌۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"اِنَّ اَ۬لذِينَ فَتَنُواْ اُ۬لْمُومِنِينَ وَالْمُومِنَٰتِ ثُمَّ لَمْ يَتُوبُواْ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ اُ۬لْحَرِيقِۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"إِنَّ اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ لَهُمْ جَنَّٰتٞ تَجْرِے مِن تَحْتِهَا اَ۬لَانْهَٰرُۖ ذَٰلِكَ اَ۬لْفَوْزُ اُ۬لْكَبِيرُۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"۞ إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"اِنَّهُۥ هُوَ يُبْدِۓُ وَيُعِيدُۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"وَهُوَ اَ۬لْغَفُورُ اُ۬لْوَدُودُ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"ذُو اُ۬لْعَرْشِۖ اِ۬لْمَجِيدُ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"فَعَّالٞ لِّمَا يُرِيدُۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"هَلَ اَت۪يٰكَ حَدِيثُ اُ۬لْجُنُودِ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"فِرْعَوْنَ وَثَمُودَۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"بَلِ اِ۬لذِينَ كَفَرُواْ فِے تَكْذِيبٖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"وَاللَّهُ مِنْ وَّرَآئِهِم مُّحِيطُۢۖ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"بَلْ هُوَ قُرْءَانٞ مَّجِيدٞ"},{"jozz":30,"sura_no":85,"sura_name_ar":"البُرُوج ","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"فِے لَوْحٖ مَّحْفُوظٞۖ"}]