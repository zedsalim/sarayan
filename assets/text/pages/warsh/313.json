[{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"وَأَنَا اَ۪خْتَرْتُكَ فَاسْتَمِعْ لِمَا يُوح۪ىٰٓ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"إِنَّنِيَ أَنَا اَ۬للَّهُ لَآ إِلَٰهَ إِلَّآ أَنَا فَاعْبُدْنِے وَأَقِمِ اِ۬لصَّلَوٰةَ لِذِكْرِيَۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"إِنَّ اَ۬لسَّاعَةَ ءَاتِيَةٌ اَكَادُ أُخْفِيهَا لِتُجْز۪ىٰ كُلُّ نَفْسِۢ بِمَا تَسْع۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"فَلَا يَصُدَّنَّكَ عَنْهَا مَن لَّا يُومِنُ بِهَا وَاتَّبَعَ هَو۪يٰهُ فَتَرْد۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"وَمَا تِلْكَ بِيَمِينِكَ يَٰمُوس۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"قَالَ هِيَ عَصَايَ أَتَوَكَّؤُاْ عَلَيْهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِے وَلِيَ فِيهَا مَـَٔارِبُ أُخْر۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"قَالَ أَلْقِهَا يَٰمُوس۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"فَأَلْق۪يٰهَا فَإِذَا هِيَ حَيَّةٞ تَسْع۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"قَالَ خُذْهَا وَلَا تَخَفْ سَنُعِيدُهَا سِيرَتَهَا اَ۬لُاول۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"وَاضْمُمْ يَدَكَ إِلَىٰ جَنَاحِكَ تَخْرُجْ بَيْضَآءَ مِنْ غَيْرِ سُوٓءٍ اٰيَةً ا۟خْر۪ىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"لِنُرِيَكَ مِنَ اٰيَٰتِنَا اَ۬لْكُبْرَىۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"اَ۪ذْهَبِ اِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغ۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"قَالَ رَبِّ اِ۪شْرَحْ لِے صَدْرِے"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"وَيَسِّرْ لِيَ أَمْرِے"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"وَاحْلُلْ عُقْدَةٗ مِّن لِّسَانِے"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"يَفْقَهُواْ قَوْلِے"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"وَاجْعَل لِّے وَزِيراٗ مِّنَ اَهْلِے"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"هَٰرُونَ أَخِےۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"اِ۟شْدُدْ بِهِۦٓ أَزْرِے"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":31,"aya_no_marker":"ﰞ","aya_text":"وَأَشْرِكْهُ فِےٓ أَمْرِے"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":32,"aya_no_marker":"ﰟ","aya_text":"كَےْ نُسَبِّحَكَ كَثِيراٗ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":33,"aya_no_marker":"ﰠ","aya_text":"وَنَذْكُرَكَ كَثِيراً"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":34,"aya_no_marker":"ﰡ","aya_text":"اِنَّكَ كُنتَ بِنَا بَصِيراٗۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":35,"aya_no_marker":"ﰢ","aya_text":"۞ قَالَ قَدُ ا۟وتِيتَ سُؤْلَكَ يَٰمُوس۪ىٰۖ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه ","aya_no":36,"aya_no_marker":"ﰣ","aya_text":"وَلَقَدْ مَنَنَّا عَلَيْكَ مَرَّةً ا۟خْر۪ىٰٓ"}]