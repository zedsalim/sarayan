[{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":44,"aya_no_marker":"ﰫ","aya_text":"وَأَنَّهُۥ خَلَقَ اَ۬لزَّوْجَيْنِ اِ۬لذَّكَرَ وَالُانث۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"مِن نُّطْفَةٍ اِذَا تُمْن۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"۞ وَأَنَّ عَلَيْهِ اِ۬لنَّشْأَةَ اَ۬لُاخْر۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":47,"aya_no_marker":"ﰮ","aya_text":"وَأَنَّهُۥ هُوَ أَغْن۪ىٰ وَأَقْن۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"وَأَنَّهُۥ هُوَ رَبُّ اُ۬لشِّعْر۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"وَأَنَّهُۥٓ أَهْلَكَ عَاداٗ اَ۬لُّاول۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"وَثَمُوداٗ فَمَآ أَبْق۪ىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"وَقَوْمَ نُوحٖ مِّن قَبْلُۖ إِنَّهُمْ كَانُواْ هُمُۥٓ أَظْلَمَ وَأَطْغ۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"وَالْمُوتَفِكَةَ أَهْو۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"فَغَشّ۪يٰهَا مَا غَشّ۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"فَبِأَيِّ ءَالَآءِ رَبِّكَ تَتَمَار۪ىٰۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"هَٰذَا نَذِيرٞ مِّنَ اَ۬لنُّذُرِ اِ۬لُاول۪ىٰٓۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"أَزِفَتِ اِ۬لَازِفَةُۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"لَيْسَ لَهَا مِن دُونِ اِ۬للَّهِ كَاشِفَةٌۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"اَفَمِنْ هَٰذَا اَ۬لْحَدِيثِ تَعْجَبُونَ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"وَتَضْحَكُونَ وَلَا تَبْكُونَ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"وَأَنتُمْ سَٰمِدُونَۖ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم ","aya_no":61,"aya_no_marker":"ﰼ","aya_text":"فَاسْجُدُواْ لِلهِ وَاعْبُدُواْۖ۩"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"اُ۪قْتَرَبَتِ اِ۬لسَّاعَةُ وَانشَقَّ اَ۬لْقَمَرُۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَإِنْ يَّرَوَاْ اٰيَةٗ يُعْرِضُواْ وَيَقُولُواْ سِحْرٞ مُّسْتَمِرّٞۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَكَذَّبُواْ وَاتَّبَعُوٓاْ أَهْوَآءَهُمْۖ وَكُلُّ أَمْرٖ مُّسْتَقِرّٞۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَلَقَدْ جَآءَهُم مِّنَ اَ۬لَانۢبَآءِ مَا فِيهِ مُزْدَجَرٌۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"حِكْمَةُۢ بَٰلِغَةٞۖ فَمَا تُغْنِ اِ۬لنُّذُرُۖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"فَتَوَلَّ عَنْهُمْۖ يَوْمَ يَدْعُ اُ۬لدَّاعِۦٓ إِلَىٰ شَےْءٖ نُّكُرٍ"}]