[{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَالسَّمَآءِ ذَاتِ اِ۬لْحُبُكِ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"إِنَّكُمْ لَفِے قَوْلٖ مُّخْتَلِفٖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"يُوفَكُ عَنْهُ مَنُ ا۟فِكَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"قُتِلَ اَ۬لْخَرَّٰصُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"اَ۬لذِينَ هُمْ فِے غَمْرَةٖ سَاهُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"يَسْـَٔلُونَ أَيَّانَ يَوْمُ اُ۬لدِّينِ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"يَوْمَ هُمْ عَلَى اَ۬لنّ۪ارِ يُفْتَنُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"ذُوقُواْ فِتْنَتَكُمْۖ هَٰذَا اَ۬لذِے كُنتُم بِهِۦ تَسْتَعْجِلُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"إِنَّ اَ۬لْمُتَّقِينَ فِے جَنَّٰتٖ وَعُيُونٍ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"اٰخِذِينَ مَآ ءَات۪يٰهُمْ رَبُّهُمُۥٓۖ إِنَّهُمْ كَانُواْ قَبْلَ ذَٰلِكَ مُحْسِنِينَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"كَانُواْ قَلِيلاٗۖ مِّنَ اَ۬ليْلِ مَا يَهْجَعُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"وَبِالَاسْح۪ارِ هُمْ يَسْتَغْفِرُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"وَفِےٓ أَمْوَٰلِهِمْ حَقّٞ لِّلسَّآئِلِ وَالْمَحْرُومِۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"وَفِے اِ۬لَارْضِ ءَايَٰتٞ لِّلْمُوقِنِينَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"وَفِےٓ أَنفُسِكُمُۥٓۖ أَفَلَا تُبْصِرُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"وَفِے اِ۬لسَّمَآءِ رِزْقُكُمْۖ وَمَا تُوعَدُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"فَوَرَبِّ اِ۬لسَّمَآءِ وَالَارْضِ إِنَّهُۥ لَحَقّٞ مِّثْلَ مَآ أَنَّكُمْ تَنطِقُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"هَلَ اَت۪يٰكَ حَدِيثُ ضَيْفِ إِبْرَٰهِيمَ اَ۬لْمُكْرَمِينَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"إِذْ دَخَلُواْ عَلَيْهِ فَقَالُواْ سَلَٰماٗۖ قَالَ سَلَٰمٞۖ قَوْمٞ مُّنكَرُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"فَرَاغَ إِلَىٰٓ أَهْلِهِۦ فَجَآءَ بِعِجْلٖ سَمِينٖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"فَقَرَّبَهُۥٓ إِلَيْهِمْ قَالَ أَلَا تَاكُلُونَۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"فَأَوْجَسَ مِنْهُمْ خِيفَةٗۖ قَالُواْ لَا تَخَفْۖ وَبَشَّرُوهُ بِغُلَٰمٍ عَلِيمٖۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"فَأَقْبَلَتِ اِ۪مْرَأَتُهُۥ فِے صَرَّةٖ فَصَكَّتْ وَجْهَهَا وَقَالَتْ عَجُوزٌ عَقِيمٞۖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"قَالُواْ كَذَٰلِكِ قَالَ رَبُّكِۖ إِنَّهُۥ هُوَ اَ۬لْحَكِيمُ اُ۬لْعَلِيمُۖ"}]