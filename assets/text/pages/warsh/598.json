[{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"أَرَٰٓيْتَ إِن كَذَّبَ وَتَوَلّ۪ىٰٓ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"أَلَمْ يَعْلَم بِأَنَّ اَ۬للَّهَ يَر۪ىٰۖ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"كَلَّا لَئِن لَّمْ يَنتَهِ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"لَنَسْفَعاَۢ بِالنَّاصِيَةِ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖۖ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"فَلْيَدْعُ نَادِيَهُۥ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"سَنَدْعُ اُ۬لزَّبَانِيَةَۖ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِبِۖ۩"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"اِنَّآ أَنزَلْنَٰهُ فِے لَيْلَةِ اِ۬لْقَدْرِۖ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَمَآ أَدْر۪يٰكَ مَا لَيْلَةُ اُ۬لْقَدْرِۖ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"لَيْلَةُ اُ۬لْقَدْرِ خَيْرٞ مِّنَ اَلْفِ شَهْرٖۖ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"تَنَزَّلُ اُ۬لْمَلَٰٓئِكَةُ وَالرُّوحُ فِيهَا بِإِذْنِ رَبِّهِم مِّن كُلِّ أَمْرٖۖ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"سَلَٰمٌ هِيَ حَتَّىٰ مَطْلَعِ اِ۬لْفَجْرِۖ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"لَمْ يَكُنِ اِ۬لذِينَ كَفَرُواْ مِنَ اَهْلِ اِ۬لْكِتَٰبِ وَالْمُشْرِكِينَ مُنفَكِّينَ حَتَّىٰ تَاتِيَهُمُ اُ۬لْبَيِّنَةُۖ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"رَسُولٞ مِّنَ اَ۬للَّهِ يَتْلُواْ صُحُفاٗ مُّطَهَّرَةٗ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"فِيهَا كُتُبٞ قَيِّمَةٞۖ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَمَا تَفَرَّقَ اَ۬لذِينَ أُوتُواْ اُ۬لْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَتْهُمُ اُ۬لْبَيِّنَةُۖ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَمَآ أُمِرُوٓاْ إِلَّا لِيَعْبُدُواْ اُ۬للَّهَ مُخْلِصِينَ لَهُ اُ۬لدِّينَ حُنَفَآءَ وَيُقِيمُواْ اُ۬لصَّلَوٰةَ وَيُوتُواْ اُ۬لزَّكَوٰةَۖ وَذَٰلِكَ دِينُ اُ۬لْقَيِّمَةِۖ"}]