[{"jozz":1,"sura_no":1,"sura_name_ar":"الفَاتِحة ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"اِ۬لْحَمْدُ لِلهِ رَبِّ اِ۬لْعَٰلَمِينَ"},{"jozz":1,"sura_no":1,"sura_name_ar":"الفَاتِحة ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"اَ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ"},{"jozz":1,"sura_no":1,"sura_name_ar":"الفَاتِحة ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"مَلِكِ يَوْمِ اِ۬لدِّينِۖ"},{"jozz":1,"sura_no":1,"sura_name_ar":"الفَاتِحة ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُۖ"},{"jozz":1,"sura_no":1,"sura_name_ar":"الفَاتِحة ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"اُ۪هْدِنَا اَ۬لصِّرَٰطَ اَ۬لْمُسْتَقِيمَ"},{"jozz":1,"sura_no":1,"sura_name_ar":"الفَاتِحة ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"صِرَٰطَ اَ۬لذِينَ أَنْعَمْتَ عَلَيْهِمْ"},{"jozz":1,"sura_no":1,"sura_name_ar":"الفَاتِحة ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"غَيْرِ اِ۬لْمَغْضُوبِ عَلَيْهِمْ وَلَا اَ۬لضَّآلِّينَۖ"}]