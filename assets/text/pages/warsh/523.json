[{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"كَذَٰلِكَۖ مَآ أَتَى اَ۬لذِينَ مِن قَبْلِهِم مِّن رَّسُولٍ اِلَّا قَالُواْ سَاحِرٌ اَوْ مَجْنُونٌۖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"اَتَوَاصَوْاْ بِهِۦۖ بَلْ هُمْ قَوْمٞ طَاغُونَۖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"وَذَكِّرْۖ فَإِنَّ اَ۬لذِّكْر۪ىٰ تَنفَعُ اُ۬لْمُومِنِينَۖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"۞ وَمَا خَلَقْتُ اُ۬لْجِنَّ وَالِانسَ إِلَّا لِيَعْبُدُونِۖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٖ وَمَآ أُرِيدُ أَنْ يُّطْعِمُونِۖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"إِنَّ اَ۬للَّهَ هُوَ اَ۬لرَّزَّاقُ ذُو اُ۬لْقُوَّةِ اِ۬لْمَتِينُۖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"فَإِنَّ لِلذِينَ ظَلَمُواْ ذَنُوباٗ مِّثْلَ ذَنُوبِ أَصْحَٰبِهِمْ فَلَا يَسْتَعْجِلُونِۖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات ","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"فَوَيْلٞ لِّلذِينَ كَفَرُواْ مِنْ يَّوْمِهِمُ اُ۬لذِے يُوعَدُونَۖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَالطُّورِ وَكِتَٰبٖ مَّسْطُورٖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"فِے رَقّٖ مَّنشُورٖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَالْبَيْتِ اِ۬لْمَعْمُورِ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَالسَّقْفِ اِ۬لْمَرْفُوعِ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَالْبَحْرِ اِ۬لْمَسْجُورِ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِنَّ عَذَابَ رَبِّكَ لَوَٰقِعٞۖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"مَّا لَهُۥ مِن دَافِعٖۖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"يَوْمَ تَمُورُ اُ۬لسَّمَآءُ مَوْراٗ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَتَسِيرُ اُ۬لْجِبَالُ سَيْراٗۖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"فَوَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"اَ۬لذِينَ هُمْ فِے خَوْضٖ يَلْعَبُونَۖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور ","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"يَوْمَ يُدَعُّونَ إِلَىٰ ن۪ارِ جَهَنَّمَ دَعّاًۖ هَٰذِهِ اِ۬لنَّارُ اُ۬لتِے كُنتُم بِهَا تُكَذِّبُونَۖ"}]