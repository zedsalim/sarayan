[{"jozz":30,"sura_no":103,"sura_name_ar":"العَصر ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَالْعَصْرِ إِنَّ اَ۬لِانسَٰنَ لَفِے خُسْرٍ"},{"jozz":30,"sura_no":103,"sura_name_ar":"العَصر ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"اِلَّا اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ وَتَوَاصَوْاْ بِالْحَقِّ"},{"jozz":30,"sura_no":103,"sura_name_ar":"العَصر ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَتَوَاصَوْاْ بِالصَّبْرِۖ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَيْلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"اِ۬لذِے جَمَعَ مَالاٗ وَعَدَّدَهُۥ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"يَحْسِبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"كَلَّاۖ لَيُنۢبَذَنَّ فِے اِ۬لْحُطَمَةِۖ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَمَآ أَدْر۪يٰكَ مَا اَ۬لْحُطَمَةُۖ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"نَارُ اُ۬للَّهِ اِ۬لْمُوقَدَةُ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"اُ۬لتِے تَطَّلِعُ عَلَى اَ۬لَافْـِٕدَةِۖ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"إِنَّهَا عَلَيْهِم مُّوصَدَةٞ"},{"jozz":30,"sura_no":104,"sura_name_ar":"الهُمَزة ","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"فِے عَمَدٖ مُّمَدَّدَةٍۖ"},{"jozz":30,"sura_no":105,"sura_name_ar":"الفِيل ","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"اَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَٰبِ اِ۬لْفِيلِۖ"},{"jozz":30,"sura_no":105,"sura_name_ar":"الفِيل ","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"أَلَمْ يَجْعَلْ كَيْدَهُمْ فِے تَضْلِيلٖ"},{"jozz":30,"sura_no":105,"sura_name_ar":"الفِيل ","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَأَرْسَلَ عَلَيْهِمْ طَيْراً اَبَابِيلَ"},{"jozz":30,"sura_no":105,"sura_name_ar":"الفِيل ","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"تَرْمِيهِم بِحِجَارَةٖ مِّن سِجِّيلٖ"},{"jozz":30,"sura_no":105,"sura_name_ar":"الفِيل ","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"فَجَعَلَهُمْ كَعَصْفٖ مَّاكُولٖۖ"}]