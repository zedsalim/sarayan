[{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"إِنَّا بَلَوْنَٰهُمْ كَمَا بَلَوْنَآ أَصْحَٰبَ اَ۬لْجَنَّةِ إِذَ اَقْسَمُواْ لَيَصْرِمُنَّهَا مُصْبِحِينَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"وَلَا يَسْتَثْنُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"۞ فَطَافَ عَلَيْهَا طَآئِفٞ مِّن رَّبِّكَ وَهُمْ نَآئِمُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"فَأَصْبَحَتْ كَالصَّرِيمِۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"فَتَنَادَوْاْ مُصْبِحِينَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"أَنُ اُ۟غْدُواْ عَلَىٰ حَرْثِكُمُۥٓ إِن كُنتُمْ صَٰرِمِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"فَانطَلَقُواْ وَهُمْ يَتَخَٰفَتُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"أَن لَّا يَدْخُلَنَّهَا اَ۬لْيَوْمَ عَلَيْكُم مِّسْكِينٞۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"وَغَدَوْاْ عَلَىٰ حَرْدٖ قَٰدِرِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"فَلَمَّا رَأَوْهَا قَالُوٓاْ إِنَّا لَضَآلُّونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"بَلْ نَحْنُ مَحْرُومُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"قَالَ أَوْسَطُهُمُۥٓ أَلَمَ اَقُل لَّكُمْ لَوْلَا تُسَبِّحُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"قَالُواْ سُبْحَٰنَ رَبِّنَآ إِنَّا كُنَّا ظَٰلِمِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٖ يَتَلَٰوَمُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":31,"aya_no_marker":"ﰞ","aya_text":"قَالُواْ يَٰوَيْلَنَآ إِنَّا كُنَّا طَٰغِينَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":32,"aya_no_marker":"ﰟ","aya_text":"عَس۪ىٰ رَبُّنَآ أَنْ يُّبَدِّلَنَا خَيْراٗ مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":33,"aya_no_marker":"ﰠ","aya_text":"كَذَٰلِكَ اَ۬لْعَذَابُۖ وَلَعَذَابُ اُ۬لَاخِرَةِ أَكْبَرُ لَوْ كَانُواْ يَعْلَمُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":34,"aya_no_marker":"ﰡ","aya_text":"إِنَّ لِلْمُتَّقِينَ عِندَ رَبِّهِمْ جَنَّٰتِ اِ۬لنَّعِيمِۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":35,"aya_no_marker":"ﰢ","aya_text":"أَفَنَجْعَلُ اُ۬لْمُسْلِمِينَ كَالْمُجْرِمِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":36,"aya_no_marker":"ﰣ","aya_text":"مَا لَكُمْۖ كَيْفَ تَحْكُمُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":37,"aya_no_marker":"ﰤ","aya_text":"أَمْ لَكُمْ كِتَٰبٞ فِيهِ تَدْرُسُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":38,"aya_no_marker":"ﰥ","aya_text":"إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":39,"aya_no_marker":"ﰦ","aya_text":"أَمْ لَكُمُۥٓ أَيْمَٰنٌ عَلَيْنَا بَٰلِغَةٌ اِلَىٰ يَوْمِ اِ۬لْقِيَٰمَةِ إِنَّ لَكُمْ لَمَا تَحْكُمُونَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":40,"aya_no_marker":"ﰧ","aya_text":"سَلْهُمُۥٓ أَيُّهُم بِذَٰلِكَ زَعِيمٌۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":41,"aya_no_marker":"ﰨ","aya_text":"اَمْ لَهُمْ شُرَكَآءُ فَلْيَاتُواْ بِشُرَكَآئِهِمُۥٓ إِن كَانُواْ صَٰدِقِينَۖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم ","aya_no":42,"aya_no_marker":"ﰩ","aya_text":"يَوْمَ يُكْشَفُ عَن سَاقٖ وَيُدْعَوْنَ إِلَى اَ۬لسُّجُودِ فَلَا يَسْتَطِيعُونَۖ"}]