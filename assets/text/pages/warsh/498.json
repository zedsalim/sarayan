[{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":38,"aya_no_marker":"ﰥ","aya_text":"إِنَّ يَوْمَ اَ۬لْفَصْلِ مِيقَٰتُهُمُۥٓ أَجْمَعِينَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":39,"aya_no_marker":"ﰦ","aya_text":"يَوْمَ لَا يُغْنِے مَوْلىً عَن مَّوْلىٗ شَئْاٗ وَلَا هُمْ يُنصَرُونَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":40,"aya_no_marker":"ﰧ","aya_text":"إِلَّا مَن رَّحِمَ اَ۬للَّهُۖ إِنَّهُۥ هُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":41,"aya_no_marker":"ﰨ","aya_text":"إِنَّ شَجَرَتَ اَ۬لزَّقُّومِ طَعَامُ اُ۬لَاثِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":42,"aya_no_marker":"ﰩ","aya_text":"كَالْمُهْلِ تَغْلِے فِے اِ۬لْبُطُونِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":43,"aya_no_marker":"ﰪ","aya_text":"كَغَلْيِ اِ۬لْحَمِيمِۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":44,"aya_no_marker":"ﰫ","aya_text":"خُذُوهُ فَاعْتُلُوهُ إِلَىٰ سَوَآءِ اِ۬لْجَحِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"ثُمَّ صُبُّواْ فَوْقَ رَأْسِهِۦ مِنْ عَذَابِ اِ۬لْحَمِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"ذُقِۖ اِنَّكَ أَنتَ اَ۬لْعَزِيزُ اُ۬لْكَرِيمُۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":47,"aya_no_marker":"ﰮ","aya_text":"إِنَّ هَٰذَا مَا كُنتُم بِهِۦ تَمْتَرُونَۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"إِنَّ اَ۬لْمُتَّقِينَ فِے مُقَامٍ اَمِينٖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"فِے جَنَّٰتٖ وَعُيُونٖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"يَلْبَسُونَ مِن سُندُسٖ وَإِسْتَبْرَقٖ مُّتَقَٰبِلِينَۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"كَذَٰلِكَۖ وَزَوَّجْنَٰهُم بِحُورٍ عِينٖۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"يَدْعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ اٰمِنِينَۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"لَا يَذُوقُونَ فِيهَا اَ۬لْمَوْتَۖ إِلَّا اَ۬لْمَوْتَةَ اَ۬لُاول۪ىٰۖ وَوَق۪يٰهُمْ عَذَابَ اَ۬لْجَحِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"فَضْلاٗ مِّن رَّبِّكَۖ ذَٰلِكَ هُوَ اَ۬لْفَوْزُ اُ۬لْعَظِيمُۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"فَإِنَّمَا يَسَّرْنَٰهُ بِلِسَانِكَ لَعَلَّهُمْ يَتَذَكَّرُونَۖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان ","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"فَارْتَقِبِۖ اِنَّهُم مُّرْتَقِبُونَۖ"}]