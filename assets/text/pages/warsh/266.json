[{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":71,"aya_no_marker":"ﱆ","aya_text":"قَالَ هَٰٓؤُلَآءِ بَنَاتِيَ إِن كُنتُمْ فَٰعِلِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":72,"aya_no_marker":"ﱇ","aya_text":"لَعَمْرُكَ إِنَّهُمْ لَفِے سَكْرَتِهِمْ يَعْمَهُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":73,"aya_no_marker":"ﱈ","aya_text":"فَأَخَذَتْهُمُ اُ۬لصَّيْحَةُ مُشْرِقِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":74,"aya_no_marker":"ﱉ","aya_text":"فَجَعَلْنَا عَٰلِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهِمْ حِجَارَةٗ مِّن سِجِّيلٍۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":75,"aya_no_marker":"ﱊ","aya_text":"اِنَّ فِے ذَٰلِكَ لَأٓيَٰتٖ لِّلْمُتَوَسِّمِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":76,"aya_no_marker":"ﱋ","aya_text":"وَإِنَّهَا لَبِسَبِيلٖ مُّقِيمٍۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":77,"aya_no_marker":"ﱌ","aya_text":"اِنَّ فِے ذَٰلِكَ لَأٓيَةٗ لِّلْمُومِنِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":78,"aya_no_marker":"ﱍ","aya_text":"۞ وَإِن كَانَ أَصْحَٰبُ اُ۬لَايْكَةِ لَظَٰلِمِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":79,"aya_no_marker":"ﱎ","aya_text":"فَانتَقَمْنَا مِنْهُمْۖ وَإِنَّهُمَا لَبِإِمَامٖ مُّبِينٖۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":80,"aya_no_marker":"ﱏ","aya_text":"وَلَقَدْ كَذَّبَ أَصْحَٰبُ اُ۬لْحِجْرِ اِ۬لْمُرْسَلِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":81,"aya_no_marker":"ﱐ","aya_text":"وَءَاتَيْنَٰهُمُۥٓ ءَايَٰتِنَا فَكَانُواْ عَنْهَا مُعْرِضِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":82,"aya_no_marker":"ﱑ","aya_text":"وَكَانُواْ يَنْحِتُونَ مِنَ اَ۬لْجِبَالِ بُيُوتاً اٰمِنِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":83,"aya_no_marker":"ﱒ","aya_text":"فَأَخَذَتْهُمُ اُ۬لصَّيْحَةُ مُصْبِحِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":84,"aya_no_marker":"ﱓ","aya_text":"فَمَآ أَغْن۪ىٰ عَنْهُم مَّا كَانُواْ يَكْسِبُونَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":85,"aya_no_marker":"ﱔ","aya_text":"وَمَا خَلَقْنَا اَ۬لسَّمَٰوَٰتِ وَالَارْضَ وَمَا بَيْنَهُمَآ إِلَّا بِالْحَقِّۖ وَإِنَّ اَ۬لسَّاعَةَ لَأٓتِيَةٞۖ فَاصْفَحِ اِ۬لصَّفْحَ اَ۬لْجَمِيلَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":86,"aya_no_marker":"ﱕ","aya_text":"إِنَّ رَبَّكَ هُوَ اَ۬لْخَلَّٰقُ اُ۬لْعَلِيمُۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":87,"aya_no_marker":"ﱖ","aya_text":"وَلَقَدَ اٰتَيْنَٰكَ سَبْعاٗ مِّنَ اَ۬لْمَثَانِے وَالْقُرْءَانَ اَ۬لْعَظِيمَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":88,"aya_no_marker":"ﱗ","aya_text":"لَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجاٗ مِّنْهُمْۖ وَلَا تَحْزَنْ عَلَيْهِمْۖ وَاخْفِضْ جَنَاحَكَ لِلْمُومِنِينَۖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":89,"aya_no_marker":"ﱘ","aya_text":"وَقُلِ اِنِّيَ أَنَا اَ۬لنَّذِيرُ اُ۬لْمُبِينُ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر ","aya_no":90,"aya_no_marker":"ﱙ","aya_text":"كَمَآ أَنزَلْنَا عَلَى اَ۬لْمُقْتَسِمِينَ"}]