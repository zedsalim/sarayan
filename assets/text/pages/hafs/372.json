[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":112,"aya_no_marker":"ﱯ","aya_text":"قَالَ وَمَا عِلۡمِي بِمَا كَانُواْ يَعۡمَلُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":113,"aya_no_marker":"ﱰ","aya_text":"إِنۡ حِسَابُهُمۡ إِلَّا عَلَىٰ رَبِّيۖ لَوۡ تَشۡعُرُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":114,"aya_no_marker":"ﱱ","aya_text":"وَمَآ أَنَا۠ بِطَارِدِ ٱلۡمُؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":115,"aya_no_marker":"ﱲ","aya_text":"إِنۡ أَنَا۠ إِلَّا نَذِيرٞ مُّبِينٞ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":116,"aya_no_marker":"ﱳ","aya_text":"قَالُواْ لَئِن لَّمۡ تَنتَهِ يَٰنُوحُ لَتَكُونَنَّ مِنَ ٱلۡمَرۡجُومِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":117,"aya_no_marker":"ﱴ","aya_text":"قَالَ رَبِّ إِنَّ قَوۡمِي كَذَّبُونِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":118,"aya_no_marker":"ﱵ","aya_text":"فَٱفۡتَحۡ بَيۡنِي وَبَيۡنَهُمۡ فَتۡحٗا وَنَجِّنِي وَمَن مَّعِيَ مِنَ ٱلۡمُؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":119,"aya_no_marker":"ﱶ","aya_text":"فَأَنجَيۡنَٰهُ وَمَن مَّعَهُۥ فِي ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":120,"aya_no_marker":"ﱷ","aya_text":"ثُمَّ أَغۡرَقۡنَا بَعۡدُ ٱلۡبَاقِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":121,"aya_no_marker":"ﱸ","aya_text":"إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":122,"aya_no_marker":"ﱹ","aya_text":"وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":123,"aya_no_marker":"ﱺ","aya_text":"كَذَّبَتۡ عَادٌ ٱلۡمُرۡسَلِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":124,"aya_no_marker":"ﱻ","aya_text":"إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ هُودٌ أَلَا تَتَّقُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":125,"aya_no_marker":"ﱼ","aya_text":"