[{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"وَأَنَّهُۥ خَلَقَ ٱلزَّوۡجَيۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"مِن نُّطۡفَةٍ إِذَا تُمۡنَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":47,"aya_no_marker":"ﰮ","aya_text":"وَأَنَّ عَلَيۡهِ ٱلنَّشۡأَةَ ٱلۡأُخۡرَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"وَأَنَّهُۥ هُوَ أَغۡنَىٰ وَأَقۡنَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"وَأَنَّهُۥٓ أَهۡلَكَ عَادًا ٱلۡأُولَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"وَثَمُودَاْ فَمَآ أَبۡقَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"وَقَوۡمَ نُوحٖ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُواْ هُمۡ أَظۡلَمَ وَأَطۡغَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"وَٱلۡمُؤۡتَفِكَةَ أَهۡوَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"فَغَشَّىٰهَا مَا غَشَّىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"فَبِأَيِّ ءَالَآءِ رَبِّكَ تَتَمَارَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"هَٰذَا نَذِيرٞ مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"أَزِفَتِ ٱلۡأٓزِفَةُ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"أَفَمِنۡ هَٰذَا ٱلۡحَدِيثِ تَعۡجَبُونَ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"وَتَضۡحَكُونَ وَلَا تَبۡكُونَ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":61,"aya_no_marker":"ﰼ","aya_text":"وَأَنتُمۡ سَٰمِدُونَ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":62,"aya_no_marker":"ﰽ","aya_text":"فَٱسۡجُدُواْۤ لِلَّهِۤ وَٱعۡبُدُواْ۩"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَإِن يَرَوۡاْ ءَايَةٗ يُعۡرِضُواْ وَيَقُولُواْ سِحۡرٞ مُّسۡتَمِرّٞ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَكَذَّبُواْ وَٱتَّبَعُوٓاْ أَهۡوَآءَهُمۡۚ وَكُلُّ أَمۡرٖ مُّسۡتَقِرّٞ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَلَقَدۡ جَآءَهُم مِّنَ ٱلۡأَنۢبَآءِ مَا فِيهِ مُزۡدَجَرٌ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"حِكۡمَةُۢ بَٰلِغَةٞۖ فَمَا تُغۡنِ ٱلنُّذُرُ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"فَتَوَلَّ عَنۡهُمۡۘ يَوۡمَ يَدۡعُ ٱلدَّاعِ إِلَىٰ شَيۡءٖ نُّكُرٍ"}]