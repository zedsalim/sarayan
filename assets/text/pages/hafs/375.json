[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":184,"aya_no_marker":"ﲷ","aya_text":"وَٱتَّقُواْ ٱلَّذِي خَلَقَكُمۡ وَٱلۡجِبِلَّةَ ٱلۡأَوَّلِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":185,"aya_no_marker":"ﲸ","aya_text":"قَالُوٓاْ إِنَّمَآ أَنتَ مِنَ ٱلۡمُسَحَّرِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":186,"aya_no_marker":"ﲹ","aya_text":"وَمَآ أَنتَ إِلَّا بَشَرٞ مِّثۡلُنَا وَإِن نَّظُنُّكَ لَمِنَ ٱلۡكَٰذِبِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":187,"aya_no_marker":"ﲺ","aya_text":"فَأَسۡقِطۡ عَلَيۡنَا كِسَفٗا مِّنَ ٱلسَّمَآءِ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":188,"aya_no_marker":"ﲻ","aya_text":"قَالَ رَبِّيٓ أَعۡلَمُ بِمَا تَعۡمَلُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":189,"aya_no_marker":"ﲼ","aya_text":"فَكَذَّبُوهُ فَأَخَذَهُمۡ عَذَابُ يَوۡمِ ٱلظُّلَّةِۚ إِنَّهُۥ كَانَ عَذَابَ يَوۡمٍ عَظِيمٍ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":190,"aya_no_marker":"ﲽ","aya_text":"إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":191,"aya_no_marker":"ﲾ","aya_text":"وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":192,"aya_no_marker":"ﲿ","aya_text":"وَإِنَّهُۥ لَتَنزِيلُ رَبِّ ٱلۡعَٰلَمِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":193,"aya_no_marker":"ﳀ","aya_text":"نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِينُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":194,"aya_no_marker":"ﳁ","aya_text":"عَلَىٰ قَلۡبِكَ لِتَكُونَ مِنَ ٱلۡمُنذِرِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":195,"aya_no_marker":"ﳂ","aya_text":"بِلِسَانٍ عَرَبِيّٖ مُّبِينٖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":196,"aya_no_marker":"ﳃ","aya_text":"وَإِنَّهُۥ لَفِي زُبُرِ ٱلۡأَوَّلِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":197,"aya_no_marker":"ﳄ","aya_text":"أَوَلَمۡ يَكُن لَّهُمۡ ءَايَةً أَن يَعۡلَمَهُۥ عُلَمَٰٓؤُاْ بَنِيٓ إِسۡرَٰٓءِيلَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":198,"aya_no_marker":"ﳅ","aya_text":"وَلَوۡ نَزَّلۡنَٰهُ عَلَىٰ بَعۡضِ ٱلۡأَعۡجَمِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":199,"aya_no_marker":"ﳆ","aya_text":"فَقَرَأَهُۥ عَلَيۡهِم مَّا كَانُواْ بِهِۦ مُؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":200,"aya_no_marker":"ﳇ","aya_text":"كَذَٰلِكَ سَلَكۡنَٰهُ فِي قُلُوبِ ٱلۡمُجۡرِمِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":201,"aya_no_marker":"ﳈ","aya_text":"لَا يُؤۡمِنُونَ بِهِۦ حَتَّىٰ يَرَوُاْ ٱلۡعَذَابَ ٱلۡأَلِيمَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":202,"aya_no_marker":"ﳉ","aya_text":"فَيَأۡتِيَهُم بَغۡتَةٗ وَهُمۡ لَا يَشۡعُرُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":203,"aya_no_marker":"ﳊ","aya_text":"فَيَقُولُواْ هَلۡ نَحۡنُ مُنظَرُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":204,"aya_no_marker":"ﳋ","aya_text":"أَفَبِعَذَابِنَا يَسۡتَعۡجِلُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":205,"aya_no_marker":"ﳌ","aya_text":"أَفَرَءَيۡتَ إِن مَّتَّعۡنَٰهُمۡ سِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":206,"aya_no_marker":"ﳍ","aya_text":"ثُمَّ جَآءَهُم مَّا كَانُواْ يُوعَدُونَ"}]