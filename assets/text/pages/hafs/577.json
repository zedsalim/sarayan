[{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"فَمَا تَنفَعُهُمۡ شَفَٰعَةُ ٱلشَّٰفِعِينَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِينَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"كَأَنَّهُمۡ حُمُرٞ مُّسۡتَنفِرَةٞ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"فَرَّتۡ مِن قَسۡوَرَةِۭ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"بَلۡ يُرِيدُ كُلُّ ٱمۡرِيٕٖ مِّنۡهُمۡ أَن يُؤۡتَىٰ صُحُفٗا مُّنَشَّرَةٗ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"كَلَّاۖ بَل لَّا يَخَافُونَ ٱلۡأٓخِرَةَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"كَلَّآ إِنَّهُۥ تَذۡكِرَةٞ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"فَمَن شَآءَ ذَكَرَهُۥ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"وَمَا يَذۡكُرُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُۚ هُوَ أَهۡلُ ٱلتَّقۡوَىٰ وَأَهۡلُ ٱلۡمَغۡفِرَةِ"},{"jozz":29,"sura_no":75,"sura_name_ar":"القِيَامة","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"لَآ أُقۡسِمُ بِيَوۡمِ ٱلۡقِيَٰمَةِ"},{"jozz":29,"sura_no":75,"sura_name_ar":"القِيَامة","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَلَآ أُقۡسِمُ بِٱلنَّفۡسِ ٱللَّوَّامَةِ"},{"jozz":29,"sura_no":75,"sura_name_ar":"القِيَامة","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"أَيَحۡسَبُ ٱلۡإِنسَٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ"},{"jozz":29,"sura_no":75,"sura_name_ar":"القِيَامة","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّيَ بَنَانَهُۥ"},{"jozz":29,"sura_no":75,"sura_name_ar":"القِيَامة","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"بَلۡ يُرِيدُ ٱلۡإِنسَٰنُ لِيَفۡجُرَ أَمَامَهُۥ"},{"jozz":29,"sura_no":75,"sura_name