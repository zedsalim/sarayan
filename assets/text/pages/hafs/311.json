[{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":77,"aya_no_marker":"ﱌ","aya_text":"أَفَرَءَيۡتَ ٱلَّذِي كَفَرَ بِـَٔايَٰتِنَا وَقَالَ لَأُوتَيَنَّ مَالٗا وَوَلَدًا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":78,"aya_no_marker":"ﱍ","aya_text":"أَطَّلَعَ ٱلۡغَيۡبَ أَمِ ٱتَّخَذَ عِندَ ٱلرَّحۡمَٰنِ عَهۡدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":79,"aya_no_marker":"ﱎ","aya_text":"كَلَّاۚ سَنَكۡتُبُ مَا يَقُولُ وَنَمُدُّ لَهُۥ مِنَ ٱلۡعَذَابِ مَدّٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":80,"aya_no_marker":"ﱏ","aya_text":"وَنَرِثُهُۥ مَا يَقُولُ وَيَأۡتِينَا فَرۡدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":81,"aya_no_marker":"ﱐ","aya_text":"وَٱتَّخَذُواْ مِن دُونِ ٱللَّهِ ءَالِهَةٗ لِّيَكُونُواْ لَهُمۡ عِزّٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":82,"aya_no_marker":"ﱑ","aya_text":"كَلَّاۚ سَيَكۡفُرُونَ بِعِبَادَتِهِمۡ وَيَكُونُونَ عَلَيۡهِمۡ ضِدًّا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":83,"aya_no_marker":"ﱒ","aya_text":"أَلَمۡ تَرَ أَنَّآ أَرۡسَلۡنَا ٱلشَّيَٰطِينَ عَلَى ٱلۡكَٰفِرِينَ تَؤُزُّهُمۡ أَزّٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":84,"aya_no_marker":"ﱓ","aya_text":"فَلَا تَعۡجَلۡ عَلَيۡهِمۡۖ إِنَّمَا نَعُدُّ لَهُمۡ عَدّٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":85,"aya_no_marker":"ﱔ","aya_text":"يَوۡمَ نَحۡشُرُ ٱلۡمُتَّقِينَ إِلَى ٱلرَّحۡمَٰنِ وَفۡدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":86,"aya_no_marker":"ﱕ","aya_text":"وَنَسُوقُ ٱلۡمُجۡرِمِينَ إِلَىٰ جَهَنَّمَ وِرۡدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":87,"aya_no_marker":"ﱖ","aya_text":"لَّا يَمۡلِكُونَ ٱلشَّفَٰعَةَ إِلَّا مَنِ ٱتَّخَذَ عِندَ ٱلرَّحۡمَٰنِ عَهۡدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":88,"aya_no_marker":"ﱗ","aya_text":"وَقَالُواْ ٱتَّخَذَ ٱلرَّحۡمَٰنُ وَلَدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":89,"aya_no_marker":"ﱘ","aya_text":"لَّقَدۡ جِئۡتُمۡ شَيۡـًٔا إِدّٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":90,"aya_no_marker":"ﱙ","aya_text":"تَكَادُ ٱلسَّمَٰوَٰتُ يَتَفَطَّرۡنَ مِنۡهُ وَتَنشَقُّ ٱلۡأَرۡضُ وَتَخِرُّ ٱلۡجِبَالُ هَدًّا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":91,"aya_no_marker":"ﱚ","aya_text":"أَن دَعَوۡاْ لِلرَّحۡمَٰنِ وَلَدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":92,"aya_no_marker":"ﱛ","aya_text":"وَمَا يَنۢبَغِي لِلرَّحۡمَٰنِ أَن يَتَّخِذَ وَلَدًا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":93,"aya_no_marker":"ﱜ","aya_text":"إِن كُلُّ مَن فِي ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ إِلَّآ ءَاتِي ٱلرَّحۡمَٰنِ عَبۡدٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":94,"aya_no_marker":"ﱝ","aya_text":"لَّقَدۡ أَحۡصَىٰهُمۡ وَعَدَّهُمۡ عَدّٗا"},{"jozz":16,"sura_no":19,"sura_name_ar":"مَريَم","aya_no":95,"aya_no_marker":"ﱞ","aya_text":"وَكُلُّهُمۡ ءَاتِيهِ يَوۡمَ ٱلۡقِيَٰمَةِ فَرۡدًا"}]