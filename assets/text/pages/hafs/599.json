[{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِنَّ ٱلَّذِينَ كَفَرُواْ مِنۡ أَهۡلِ ٱلۡكِتَٰبِ وَٱلۡمُشۡرِكِينَ فِي نَارِ جَهَنَّمَ خَٰلِدِينَ فِيهَآۚ أُوْلَٰٓئِكَ هُمۡ شَرُّ ٱلۡبَرِيَّةِ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"إِنَّ ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّٰلِحَٰتِ أُوْلَٰٓئِكَ هُمۡ خَيۡرُ ٱلۡبَرِيَّةِ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"جَزَآؤُهُمۡ عِندَ رَبِّهِمۡ جَنَّٰتُ عَدۡنٖ تَجۡرِي مِن تَحۡتِهَا ٱلۡأَنۡهَٰرُ خَٰلِدِينَ فِيهَآ أَبَدٗاۖ رَّضِيَ ٱللَّهُ عَنۡهُمۡ وَرَضُواْ عَنۡهُۚ ذَٰلِكَ لِمَنۡ خَشِيَ رَبَّهُۥ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"إِذَا زُلۡزِلَتِ ٱلۡأَرۡضُ زِلۡزَالَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَأَخۡرَجَتِ ٱلۡأَرۡضُ أَثۡقَالَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَقَالَ ٱلۡإِنسَٰنُ مَا لَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"يَوۡمَئِذٖ تُحَدِّثُ أَخۡبَارَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"بِأَنَّ رَبَّكَ أَوۡحَىٰ لَهَا"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"يَوۡمَئِذٖ يَصۡدُرُ ٱلنَّاسُ أَشۡتَاتٗا لِّيُرَوۡاْ أَعۡمَٰلَهُمۡ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"فَمَن يَعۡمَلۡ مِثۡقَالَ ذَرَّةٍ خَيۡرٗا يَرَهُۥ"},{"jozz":30,"sura_no":99,"sura_name_ar":"الزَّلزَلة","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"وَمَن يَعۡمَلۡ مِثۡقَالَ ذَرَّةٖ شَرّٗا يَرَهُۥ"},{"jozz":30,"sura_no":100,"sura_name_ar":"العَاديَات","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَٱلۡعَٰدِيَٰتِ ضَبۡحٗا"},{"jozz":30,"sura_no":100,"sura_name_ar":"العَاديَات","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"فَٱلۡمُورِيَٰتِ قَدۡحٗا"},{"jozz":30,"sura_no":100,"sura_name_ar":"العَاديَات","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"فَٱلۡمُغِيرَٰتِ صُبۡحٗا"},{"jozz":30,"sura_no":100,"sura_name_ar":"العَاديَات","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"فَأَثَرۡنَ بِهِۦ نَقۡعٗا"},{"jozz":30,"sura_no":100,"sura_name_ar":"العَاديَات","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"فَوَسَطۡنَ بِهِۦ جَمۡعًا"}]