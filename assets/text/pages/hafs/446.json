[{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَٱلصَّٰٓفَّٰتِ صَفّٗا"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"فَٱلزَّٰجِرَٰتِ زَجۡرٗا"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"فَٱلتَّٰلِيَٰتِ ذِكۡرًا"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"إِنَّ إِلَٰهَكُمۡ لَوَٰحِدٞ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ وَمَا بَيۡنَهُمَا وَرَبُّ ٱلۡمَشَٰرِقِ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنۡيَا بِزِينَةٍ ٱلۡكَوَاكِبِ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَحِفۡظٗا مِّن كُلِّ شَيۡطَٰنٖ مَّارِدٖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"لَّا يَسَّمَّعُونَ إِلَى ٱلۡمَلَإِ ٱلۡأَعۡلَىٰ وَيُقۡذَفُونَ مِن كُلِّ جَانِبٖ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"دُحُورٗاۖ وَلَهُمۡ عَذَابٞ وَاصِبٌ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"إِلَّا مَنۡ خَطِفَ ٱلۡخَطۡفَةَ فَأَتۡبَعَهُۥ شِهَابٞ ثَاقِبٞ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"فَٱسۡتَفۡتِهِمۡ أَهُمۡ أَشَدُّ خَلۡقًا أَم مَّنۡ خَلَقۡنَآۚ إِنَّا خَلَقۡنَٰهُم مِّن طِينٖ لَّازِبِۭ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"بَلۡ عَجِبۡتَ وَيَسۡخَرُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"وَإِذَا ذُكِّرُواْ لَا يَذۡكُرُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"وَإِذَا رَأَوۡاْ ءَايَةٗ يَسۡتَسۡخِرُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"وَقَالُوٓاْ إِنۡ هَٰذَآ إِلَّا سِحۡرٞ مُّبِينٌ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"أَءِذَا مِتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَءِنَّا لَمَبۡعُوثُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"أَوَءَابَآؤُنَا ٱلۡأَوَّلُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"قُلۡ نَعَمۡ وَأَنتُمۡ دَٰخِرُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"فَإِنَّمَا هِيَ زَجۡرَةٞ وَٰحِدَةٞ فَإِذَا هُمۡ يَنظُرُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"وَقَالُواْ يَٰوَيۡلَنَا هَٰذَا يَوۡمُ ٱلدِّينِ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"هَٰذَا يَوۡمُ ٱلۡفَصۡلِ ٱلَّذِي كُنتُم بِهِۦ تُكَذِّبُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"۞ ٱحۡشُرُواْ ٱلَّذِينَ ظَلَمُواْ وَأَزۡوَٰجَهُمۡ وَمَا كَانُواْ يَعۡبُدُونَ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"مِن دُونِ ٱللَّهِ فَٱهۡدُوهُمۡ إِلَىٰ صِرَٰطِ ٱلۡجَحِيمِ"},{"jozz":23,"sura_no":37,"sura_name_ar":"الصَّافَات","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"وَقِفُوهُمۡۖ إِنَّهُم مَّسۡـُٔولُونَ"}]