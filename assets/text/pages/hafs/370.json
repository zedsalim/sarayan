[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":61,"aya_no_marker":"ﰼ","aya_text":"فَلَمَّا تَرَٰٓءَا ٱلۡجَمۡعَانِ قَالَ أَصۡحَٰبُ مُوسَىٰٓ إِنَّا لَمُدۡرَكُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":62,"aya_no_marker":"ﰽ","aya_text":"قَالَ كَلَّآۖ إِنَّ مَعِيَ رَبِّي سَيَهۡدِينِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":63,"aya_no_marker":"ﰾ","aya_text":"فَأَوۡحَيۡنَآ إِلَىٰ مُوسَىٰٓ أَنِ ٱضۡرِب بِّعَصَاكَ ٱلۡبَحۡرَۖ فَٱنفَلَقَ فَكَانَ كُلُّ فِرۡقٖ كَٱلطَّوۡدِ ٱلۡعَظِيمِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":64,"aya_no_marker":"ﰿ","aya_text":"وَأَزۡلَفۡنَا ثَمَّ ٱلۡأٓخَرِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":65,"aya_no_marker":"ﱀ","aya_text":"وَأَنجَيۡنَا مُوسَىٰ وَمَن مَّعَهُۥٓ أَجۡمَعِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":66,"aya_no_marker":"ﱁ","aya_text":"ثُمَّ أَغۡرَقۡنَا ٱلۡأٓخَرِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":67,"aya_no_marker":"ﱂ","aya_text":"إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":68,"aya_no_marker":"ﱃ","aya_text":"وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":69,"aya_no_marker":"ﱄ","aya_text":"وَٱتۡلُ عَلَيۡهِمۡ نَبَأَ إِبۡرَٰهِيمَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":70,"aya_no_marker":"ﱅ","aya_text":"إِذۡ قَالَ لِأَبِيهِ وَقَوۡمِهِۦ مَا تَعۡبُدُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":71,"aya_no_marker":"ﱆ","aya_text":"قَالُواْ نَعۡبُدُ أَصۡنَامٗا فَنَظَلُّ لَهَا عَٰكِفِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":72,"aya_no_marker":"ﱇ","aya_text":"قَالَ هَلۡ يَسۡمَعُونَكُمۡ إِذۡ تَدۡعُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":73,"aya_no_marker":"ﱈ","aya_text":"أَوۡ يَنفَعُونَكُمۡ أَوۡ يَضُرُّونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":74,"aya_no_marker":"ﱉ","aya_text":"قَالُواْ بَلۡ وَجَدۡنَآ ءَابَآءَنَا كَذَٰلِكَ يَفۡعَلُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":75,"aya_no_marker":"ﱊ","aya_text":"قَالَ أَفَرَءَيۡتُم مَّا كُنتُمۡ تَعۡبُدُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":76,"aya_no_marker":"ﱋ","aya_text":"أَنتُمۡ وَءَابَآؤُكُمُ ٱلۡأَقۡدَمُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":77,"aya_no_marker":"ﱌ","aya_text":"فَإِنَّهُمۡ عَدُوّٞ لِّيٓ إِلَّا رَبَّ ٱلۡعَٰلَمِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":78,"aya_no_marker":"ﱍ","aya_text":"ٱلَّذِي خَلَقَنِي فَهُوَ يَهۡدِينِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":79,"aya_no_marker":"ﱎ","aya_text":"وَٱلَّذِي هُوَ يُطۡعِمُنِي وَيَسۡقِينِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":80,"aya_no_marker":"ﱏ","aya_text":"وَإِذَا مَرِضۡتُ فَهُوَ يَشۡفِينِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":81,"aya_no_marker":"ﱐ","aya_text":"وَٱلَّذِي يُمِيتُنِي ثُمَّ يُحۡيِينِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":82,"aya_no_marker":"ﱑ","aya_text":"وَٱلَّذِيٓ أَطۡمَعُ أَن يَغۡفِرَ لِي خَطِيٓـَٔتِي يَوۡمَ ٱلدِّينِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":83,"aya_no_marker":"ﱒ","aya_text":"رَبِّ هَبۡ لِي حُكۡمٗا وَأَلۡحِقۡنِي بِٱلصَّٰلِحِينَ"}]