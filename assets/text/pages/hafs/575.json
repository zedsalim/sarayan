[{"jozz":29,"sura_no":73,"sura_name_ar":"المُزمل","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"۞ إِنَّ رَبَّكَ يَعۡلَمُ أَنَّكَ تَقُومُ أَدۡنَىٰ مِن ثُلُثَيِ ٱلَّيۡلِ وَنِصۡفَهُۥ وَثُلُثَهُۥ وَطَآئِفَةٞ مِّنَ ٱلَّذِينَ مَعَكَۚ وَٱللَّهُ يُقَدِّرُ ٱلَّيۡلَ وَٱلنَّهَارَۚ عَلِمَ أَن لَّن تُحۡصُوهُ فَتَابَ عَلَيۡكُمۡۖ فَٱقۡرَءُواْ مَا تَيَسَّرَ مِنَ ٱلۡقُرۡءَانِۚ عَلِمَ أَن سَيَكُونُ مِنكُم مَّرۡضَىٰ وَءَاخَرُونَ يَضۡرِبُونَ فِي ٱلۡأَرۡضِ يَبۡتَغُونَ مِن فَضۡلِ ٱللَّهِ وَءَاخَرُونَ يُقَٰتِلُونَ فِي سَبِيلِ ٱللَّهِۖ فَٱقۡرَءُواْ مَا تَيَسَّرَ مِنۡهُۚ وَأَقِيمُواْ ٱلصَّلَوٰةَ وَءَاتُواْ ٱلزَّكَوٰةَ وَأَقۡرِضُواْ ٱللَّهَ قَرۡضًا حَسَنٗاۚ وَمَا تُقَدِّمُواْ لِأَنفُسِكُم مِّنۡ خَيۡرٖ تَجِدُوهُ عِندَ ٱللَّهِ هُوَ خَيۡرٗا وَأَعۡظَمَ أَجۡرٗاۚ وَٱسۡتَغۡفِرُواْ ٱللَّهَۖ إِنَّ ٱللَّهَ غَفُورٞ رَّحِيمُۢ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"يَٰٓأَيُّهَا ٱلۡمُدَّثِّرُ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"قُمۡ فَأَنذِرۡ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَرَبَّكَ فَكَبِّرۡ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَثِيَابَكَ فَطَهِّرۡ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَٱلرُّجۡزَ فَٱهۡجُرۡ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"وَلَا تَمۡنُن تَسۡتَكۡثِرُ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَلِرَبِّكَ فَٱصۡبِرۡ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"فَإِذَا نُقِرَ فِي ٱلنَّاقُورِ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"فَذَٰلِكَ يَوۡمَئِذٖ يَوۡمٌ عَسِيرٌ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"عَلَى ٱلۡكَٰفِرِينَ غَيۡرُ يَسِيرٖ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"ذَرۡنِي وَمَنۡ خَلَقۡتُ وَحِيدٗا"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"وَجَعَلۡتُ لَهُۥ مَالٗا مَّمۡدُودٗا"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"وَبَنِينَ شُهُودٗا"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"وَمَهَّدتُّ لَهُۥ تَمۡهِيدٗا"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"ثُمَّ يَطۡمَعُ أَنۡ أَزِيدَ"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"كَلَّآۖ إِنَّهُۥ كَانَ لِأٓيَٰتِنَا عَنِيدٗا"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"سَأُرۡهِقُهُۥ صَعُودًا"},{"jozz":29,"sura_no":74,"sura_name_ar":"المُدثر","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"إِنَّهُۥ فَكَّرَ وَقَدَّرَ"}]