[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":40,"aya_no_marker":"ﰧ","aya_text":"لَعَلَّنَا نَتَّبِعُ ٱلسَّحَرَةَ إِن كَانُواْ هُمُ ٱلۡغَٰلِبِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":41,"aya_no_marker":"ﰨ","aya_text":"فَلَمَّا جَآءَ ٱلسَّحَرَةُ قَالُواْ لِفِرۡعَوۡنَ أَئِنَّ لَنَا لَأَجۡرًا إِن كُنَّا نَحۡنُ ٱلۡغَٰلِبِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":42,"aya_no_marker":"ﰩ","aya_text":"قَالَ نَعَمۡ وَإِنَّكُمۡ إِذٗا لَّمِنَ ٱلۡمُقَرَّبِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":43,"aya_no_marker":"ﰪ","aya_text":"قَالَ لَهُم مُّوسَىٰٓ أَلۡقُواْ مَآ أَنتُم مُّلۡقُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":44,"aya_no_marker":"ﰫ","aya_text":"فَأَلۡقَوۡاْ حِبَالَهُمۡ وَعِصِيَّهُمۡ وَقَالُواْ بِعِزَّةِ فِرۡعَوۡنَ إِنَّا لَنَحۡنُ ٱلۡغَٰلِبُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"فَأَلۡقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِيَ تَلۡقَفُ مَا يَأۡفِكُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"فَأُلۡقِيَ ٱلسَّحَرَةُ سَٰجِدِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":47,"aya_no_marker":"ﰮ","aya_text":"قَالُوٓاْ ءَامَنَّا بِرَبِّ ٱلۡعَٰلَمِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"رَبِّ مُوسَىٰ وَهَٰرُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"قَالَ ءَامَنتُمۡ لَهُۥ قَبۡلَ أَنۡ ءَاذَنَ لَكُمۡۖ إِنَّهُۥ لَكَبِيرُكُمُ ٱلَّذِي عَلَّمَكُمُ ٱلسِّحۡرَ فَلَسَوۡفَ تَعۡلَمُونَۚ لَأُقَطِّعَنَّ أَيۡدِيَكُمۡ وَأَرۡجُلَكُم مِّنۡ خِلَٰفٖ وَلَأُصَلِّبَنَّكُمۡ أَجۡمَعِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"قَالُواْ لَا ضَيۡرَۖ إِنَّآ إِلَىٰ رَبِّنَا مُنقَلِبُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"إِنَّا نَطۡمَعُ أَن يَغۡفِرَ لَنَا رَبُّنَا خَطَٰيَٰنَآ أَن كُنَّآ أَوَّلَ ٱلۡمُؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"۞ وَأَوۡحَيۡنَآ إِلَىٰ مُوسَىٰٓ أَنۡ أَسۡرِ بِعِبَادِيٓ إِنَّكُم مُّتَّبَعُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"فَأَرۡسَلَ فِرۡعَوۡنُ فِي ٱلۡمَدَآئِنِ حَٰشِرِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"إِنَّ هَٰٓؤُلَآءِ لَشِرۡذِمَةٞ قَلِيلُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"وَإِنَّهُمۡ لَنَا لَغَآئِظُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"وَإِنَّا لَجَمِيعٌ حَٰذِرُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"فَأَخۡرَجۡنَٰهُم مِّن جَنَّٰتٖ وَعُيُونٖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"وَكُنُوزٖ وَمَقَامٖ كَرِيمٖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"كَذَٰلِكَۖ وَأَوۡرَثۡنَٰهَا بَنِيٓ إِسۡرَٰٓءِيلَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"فَأَتۡبَعُوهُم مُّشۡرِقِينَ"}]