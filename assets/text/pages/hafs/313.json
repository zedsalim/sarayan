[{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"وَأَنَا ٱخۡتَرۡتُكَ فَٱسۡتَمِعۡ لِمَا يُوحَىٰٓ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"إِنَّنِيٓ أَنَا ٱللَّهُ لَآ إِلَٰهَ إِلَّآ أَنَا۠ فَٱعۡبُدۡنِي وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِيٓ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"إِنَّ ٱلسَّاعَةَ ءَاتِيَةٌ أَكَادُ أُخۡفِيهَا لِتُجۡزَىٰ كُلُّ نَفۡسِۭ بِمَا تَسۡعَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"فَلَا يَصُدَّنَّكَ عَنۡهَا مَن لَّا يُؤۡمِنُ بِهَا وَٱتَّبَعَ هَوَىٰهُ فَتَرۡدَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"وَمَا تِلۡكَ بِيَمِينِكَ يَٰمُوسَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"قَالَ هِيَ عَصَايَ أَتَوَكَّؤُاْ عَلَيۡهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِي وَلِيَ فِيهَا مَـَٔارِبُ أُخۡرَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"قَالَ أَلۡقِهَا يَٰمُوسَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"فَأَلۡقَىٰهَا فَإِذَا هِيَ حَيَّةٞ تَسۡعَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"قَالَ خُذۡهَا وَلَا تَخَفۡۖ سَنُعِيدُهَا سِيرَتَهَا ٱلۡأُولَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"وَٱضۡمُمۡ يَدَكَ إِلَىٰ جَنَاحِكَ تَخۡرُجۡ بَيۡضَآءَ مِنۡ غَيۡرِ سُوٓءٍ ءَايَةً أُخۡرَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"لِنُرِيَكَ مِنۡ ءَايَٰتِنَا ٱلۡكُبۡرَى"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"ٱذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"قَالَ رَبِّ ٱشۡرَحۡ لِي صَدۡرِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"وَيَسِّرۡ لِيٓ أَمۡرِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"وَٱحۡلُلۡ عُقۡدَةٗ مِّن لِّسَانِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"يَفۡقَهُواْ قَوۡلِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"وَٱجۡعَل لِّي وَزِيرٗا مِّنۡ أَهۡلِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"هَٰرُونَ أَخِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":31,"aya_no_marker":"ﰞ","aya_text":"ٱشۡدُدۡ بِهِۦٓ أَزۡرِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":32,"aya_no_marker":"ﰟ","aya_text":"وَأَشۡرِكۡهُ فِيٓ أَمۡرِي"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":33,"aya_no_marker":"ﰠ","aya_text":"كَيۡ نُسَبِّحَكَ كَثِيرٗا"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":34,"aya_no_marker":"ﰡ","aya_text":"وَنَذۡكُرَكَ كَثِيرًا"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":35,"aya_no_marker":"ﰢ","aya_text":"إِنَّكَ كُنتَ بِنَا بَصِيرٗا"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":36,"aya_no_marker":"ﰣ","aya_text":"قَالَ قَدۡ أُوتِيتَ سُؤۡلَكَ يَٰمُوسَىٰ"},{"jozz":16,"sura_no":20,"sura_name_ar":"طه","aya_no":37,"aya_no_marker":"ﰤ","aya_text":"وَلَقَدۡ مَنَنَّا عَلَيۡكَ مَرَّةً أُخۡرَىٰٓ"}]