[{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"قَدۡ أَفۡلَحَ ٱلۡمُؤۡمِنُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"ٱلَّذِينَ هُمۡ فِي صَلَاتِهِمۡ خَٰشِعُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَٱلَّذِينَ هُمۡ عَنِ ٱللَّغۡوِ مُعۡرِضُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَٱلَّذِينَ هُمۡ لِلزَّكَوٰةِ فَٰعِلُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَٱلَّذِينَ هُمۡ لِفُرُوجِهِمۡ حَٰفِظُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"إِلَّا عَلَىٰٓ أَزۡوَٰجِهِمۡ أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمۡ فَإِنَّهُمۡ غَيۡرُ مَلُومِينَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"فَمَنِ ٱبۡتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ ٱلۡعَادُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"وَٱلَّذِينَ هُمۡ لِأَمَٰنَٰتِهِمۡ وَعَهۡدِهِمۡ رَٰعُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَٱلَّذِينَ هُمۡ عَلَىٰ صَلَوَٰتِهِمۡ يُحَافِظُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"أُوْلَٰٓئِكَ هُمُ ٱلۡوَٰرِثُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"ٱلَّذِينَ يَرِثُونَ ٱلۡفِرۡدَوۡسَ هُمۡ فِيهَا خَٰلِدُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"وَلَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ مِن سُلَٰلَةٖ مِّن طِينٖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"ثُمَّ جَعَلۡنَٰهُ نُطۡفَةٗ فِي قَرَارٖ مَّكِينٖ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"ثُمَّ خَلَقۡنَا ٱلنُّطۡفَةَ عَلَقَةٗ فَخَلَقۡنَا ٱلۡعَلَقَةَ مُضۡغَةٗ فَخَلَقۡنَا ٱلۡمُضۡغَةَ عِظَٰمٗا فَكَسَوۡنَا ٱلۡعِظَٰمَ لَحۡمٗا ثُمَّ أَنشَأۡنَٰهُ خَلۡقًا ءَاخَرَۚ فَتَبَارَكَ ٱللَّهُ أَحۡسَنُ ٱلۡخَٰلِقِينَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"ثُمَّ إِنَّكُم بَعۡدَ ذَٰلِكَ لَمَيِّتُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"ثُمَّ إِنَّكُمۡ يَوۡمَ ٱلۡقِيَٰمَةِ تُبۡعَثُونَ"},{"jozz":18,"sura_no":23,"sura_name_ar":"المؤمنُون","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"وَلَقَدۡ خَلَقۡنَا فَوۡقَكُمۡ سَبۡعَ طَرَآئِقَ وَمَا كُنَّا عَنِ ٱلۡخَلۡقِ غَٰفِلِينَ"}]