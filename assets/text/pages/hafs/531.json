[{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"وَمَآ أَمۡرُنَآ إِلَّا وَٰحِدَةٞ كَلَمۡحِۭ بِٱلۡبَصَرِ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"وَلَقَدۡ أَهۡلَكۡنَآ أَشۡيَاعَكُمۡ فَهَلۡ مِن مُّدَّكِرٖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"وَكُلُّ شَيۡءٖ فَعَلُوهُ فِي ٱلزُّبُرِ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"وَكُلُّ صَغِيرٖ وَكَبِيرٖ مُّسۡتَطَرٌ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"إِنَّ ٱلۡمُتَّقِينَ فِي جَنَّٰتٖ وَنَهَرٖ"},{"jozz":27,"sura_no":54,"sura_name_ar":"القَمَر","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"فِي مَقۡعَدِ صِدۡقٍ عِندَ مَلِيكٖ مُّقۡتَدِرِۭ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"ٱلرَّحۡمَٰنُ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"عَلَّمَ ٱلۡقُرۡءَانَ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"خَلَقَ ٱلۡإِنسَٰنَ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"عَلَّمَهُ ٱلۡبَيَانَ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"ٱلشَّمۡسُ وَٱلۡقَمَرُ بِحُسۡبَانٖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"وَٱلنَّجۡمُ وَٱلشَّجَرُ يَسۡجُدَانِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلۡمِيزَانَ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"أَلَّا تَطۡغَوۡاْ فِي ٱلۡمِيزَانِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَأَقِيمُواْ ٱلۡوَزۡنَ بِٱلۡقِسۡطِ وَلَا تُخۡسِرُواْ ٱلۡمِيزَانَ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"وَٱلۡأَرۡضَ وَضَعَهَا لِلۡأَنَامِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"فِيهَا فَٰكِهَةٞ وَٱلنَّخۡلُ ذَاتُ ٱلۡأَكۡمَامِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"وَٱلۡحَبُّ ذُو ٱلۡعَصۡفِ وَٱلرَّيۡحَانُ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"خَلَقَ ٱلۡإِنسَٰنَ مِن صَلۡصَٰلٖ كَٱلۡفَخَّارِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"وَخَلَقَ ٱلۡجَآنَّ مِن مَّارِجٖ مِّن نَّارٖ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"رَبُّ ٱلۡمَشۡرِقَيۡنِ وَرَبُّ ٱلۡمَغۡرِبَيۡنِ"},{"jozz":27,"sura_no":55,"sura_name_ar":"الرَّحمٰن","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"}]