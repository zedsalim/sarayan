[{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"إِذۡ دَخَلُواْ عَلَيۡهِ فَقَالُواْ سَلَٰمٗا قَالَ إِنَّا مِنكُمۡ وَجِلُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"قَالُواْ لَا تَوۡجَلۡ إِنَّا نُبَشِّرُكَ بِغُلَٰمٍ عَلِيمٖ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"قَالَ أَبَشَّرۡتُمُونِي عَلَىٰٓ أَن مَّسَّنِيَ ٱلۡكِبَرُ فَبِمَ تُبَشِّرُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"قَالُواْ بَشَّرۡنَٰكَ بِٱلۡحَقِّ فَلَا تَكُن مِّنَ ٱلۡقَٰنِطِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"قَالَ وَمَن يَقۡنَطُ مِن رَّحۡمَةِ رَبِّهِۦٓ إِلَّا ٱلضَّآلُّونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"قَالَ فَمَا خَطۡبُكُمۡ أَيُّهَا ٱلۡمُرۡسَلُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"قَالُوٓاْ إِنَّآ أُرۡسِلۡنَآ إِلَىٰ قَوۡمٖ مُّجۡرِمِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"إِلَّآ ءَالَ لُوطٍ إِنَّا لَمُنَجُّوهُمۡ أَجۡمَعِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"إِلَّا ٱمۡرَأَتَهُۥ قَدَّرۡنَآ إِنَّهَا لَمِنَ ٱلۡغَٰبِرِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":61,"aya_no_marker":"ﰼ","aya_text":"فَلَمَّا جَآءَ ءَالَ لُوطٍ ٱلۡمُرۡسَلُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":62,"aya_no_marker":"ﰽ","aya_text":"قَالَ إِنَّكُمۡ قَوۡمٞ مُّنكَرُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":63,"aya_no_marker":"ﰾ","aya_text":"قَالُواْ بَلۡ جِئۡنَٰكَ بِمَا كَانُواْ فِيهِ يَمۡتَرُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":64,"aya_no_marker":"ﰿ","aya_text":"وَأَتَيۡنَٰكَ بِٱلۡحَقِّ وَإِنَّا لَصَٰدِقُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":65,"aya_no_marker":"ﱀ","aya_text":"فَأَسۡرِ بِأَهۡلِكَ بِقِطۡعٖ مِّنَ ٱلَّيۡلِ وَٱتَّبِعۡ أَدۡبَٰرَهُمۡ وَلَا يَلۡتَفِتۡ مِنكُمۡ أَحَدٞ وَٱمۡضُواْ حَيۡثُ تُؤۡمَرُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":66,"aya_no_marker":"ﱁ","aya_text":"وَقَضَيۡنَآ إِلَيۡهِ ذَٰلِكَ ٱلۡأَمۡرَ أَنَّ دَابِرَ هَٰٓؤُلَآءِ مَقۡطُوعٞ مُّصۡبِحِينَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":67,"aya_no_marker":"ﱂ","aya_text":"وَجَآءَ أَهۡلُ ٱلۡمَدِينَةِ يَسۡتَبۡشِرُونَ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":68,"aya_no_marker":"ﱃ","aya_text":"قَالَ إِنَّ هَٰٓؤُلَآءِ ضَيۡفِي فَلَا تَفۡضَحُونِ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":69,"aya_no_marker":"ﱄ","aya_text":"وَٱتَّقُواْ ٱللَّهَ وَلَا تُخۡزُونِ"},{"jozz":14,"sura_no":15,"sura_name_ar":"الحِجر","aya_no":70,"aya_no_marker":"ﱅ","aya_text":"قَالُوٓاْ أَوَلَمۡ نَنۡهَكَ عَنِ ٱلۡعَٰلَمِينَ"}]