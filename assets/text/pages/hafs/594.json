[{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"وَجِاْيٓءَ يَوۡمَئِذِۭ بِجَهَنَّمَۚ يَوۡمَئِذٖ يَتَذَكَّرُ ٱلۡإِنسَٰنُ وَأَنَّىٰ لَهُ ٱلذِّكۡرَىٰ"},{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"يَقُولُ يَٰلَيۡتَنِي قَدَّمۡتُ لِحَيَاتِي"},{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"فَيَوۡمَئِذٖ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٞ"},{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَدٞ"},{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"يَٰٓأَيَّتُهَا ٱلنَّفۡسُ ٱلۡمُطۡمَئِنَّةُ"},{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"ٱرۡجِعِيٓ إِلَىٰ رَبِّكِ رَاضِيَةٗ مَّرۡضِيَّةٗ"},{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"فَٱدۡخُلِي فِي عِبَٰدِي"},{"jozz":30,"sura_no":89,"sura_name_ar":"الفَجر","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"وَٱدۡخُلِي جَنَّتِي"},{"jozz":30,"sura_no":90,"sura_name_ar":"البَلَد","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"لَآ أُقۡسِمُ بِهَٰذَا ٱلۡبَلَدِ"},{"jozz":30,"sura_no":90,"sura_name_ar":"البَلَد","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَأَنتَ حِلُّۢ بِهَٰذَا ٱلۡبَلَدِ"},{"jozz":30,"sura_no":90,"sura_name_ar":"البَلَد","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَوَالِدٖ وَمَا وَلَدَ"},{"jozz":30,"sura_no":90,"sura_name_ar":"البَلَد","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"لَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ فِي كَبَدٍ"},{"jozz":30,"sura_no":90,"sura_name_ar":"البَلَد","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"أَيَحۡسَبُ أَن لَّن يَقۡدِرَ عَلَيۡهِ أَحَدٞ"},{"jozz":30,"sura_no":90,"sura_name_ar":"البَلَد","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"يَقُولُ أَهۡلَكۡتُ مَالٗا لُّبَدًا"},{"jozz":30,"sura_no":90,"sura_name_ar":"البَلَد","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"أَيَحۡسَبُ أَن لَّمۡ يَرَهُ