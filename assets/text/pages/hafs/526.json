[{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَٱلنَّجۡمِ إِذَا هَوَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"مَا ضَلَّ صَاحِبُكُمۡ وَمَا غَوَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَمَا يَنطِقُ عَنِ ٱلۡهَوَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"إِنۡ هُوَ إِلَّا وَحۡيٞ يُوحَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"عَلَّمَهُۥ شَدِيدُ ٱلۡقُوَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"ذُو مِرَّةٖ فَٱسۡتَوَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَهُوَ بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"ثُمَّ دَنَا فَتَدَلَّىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"فَكَانَ قَابَ قَوۡسَيۡنِ أَوۡ أَدۡنَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"فَأَوۡحَىٰٓ إِلَىٰ عَبۡدِهِۦ مَآ أَوۡحَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"مَا كَذَبَ ٱلۡفُؤَادُ مَا رَأَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"وَلَقَدۡ رَءَاهُ نَزۡلَةً أُخۡرَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"عِندَ سِدۡرَةِ ٱلۡمُنتَهَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"عِندَهَا جَنَّةُ ٱلۡمَأۡوَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"إِذۡ يَغۡشَى ٱلسِّدۡرَةَ مَا يَغۡشَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"مَا زَاغَ ٱلۡبَصَرُ وَمَا طَغَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"لَقَدۡ رَأَىٰ مِنۡ ءَايَٰتِ رَبِّهِ ٱلۡكُبۡرَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"أَفَرَءَيۡتُمُ ٱللَّٰتَ وَٱلۡعُزَّىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلۡأُنثَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"تِلۡكَ إِذٗا قِسۡمَةٞ ضِيزَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"إِنۡ هِيَ إِلَّآ أَسۡمَآءٞ سَمَّيۡتُمُوهَآ أَنتُمۡ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلۡطَٰنٍۚ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهۡوَى ٱلۡأَنفُسُۖ وَلَقَدۡ جَآءَهُم مِّن رَّبِّهِمُ ٱلۡهُدَىٰٓ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"أَمۡ لِلۡإِنسَٰنِ مَا تَمَنَّىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"فَلِلَّهِ ٱلۡأٓخِرَةُ وَٱلۡأُولَىٰ"},{"jozz":27,"sura_no":53,"sura_name_ar":"النَّجم","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"۞ وَكَم مِّن مَّلَكٖ فِي ٱلسَّمَٰوَٰتِ لَا تُغۡنِي شَفَٰعَتُهُمۡ شَيۡـًٔا إِلَّا مِنۢ بَعۡدِ أَن يَأۡذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرۡضَىٰٓ"}]