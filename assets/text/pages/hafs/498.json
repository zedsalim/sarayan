[{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":40,"aya_no_marker":"ﰧ","aya_text":"إِنَّ يَوۡمَ ٱلۡفَصۡلِ مِيقَٰتُهُمۡ أَجۡمَعِينَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":41,"aya_no_marker":"ﰨ","aya_text":"يَوۡمَ لَا يُغۡنِي مَوۡلًى عَن مَّوۡلٗى شَيۡـٔٗا وَلَا هُمۡ يُنصَرُونَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":42,"aya_no_marker":"ﰩ","aya_text":"إِلَّا مَن رَّحِمَ ٱللَّهُۚ إِنَّهُۥ هُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":43,"aya_no_marker":"ﰪ","aya_text":"إِنَّ شَجَرَتَ ٱلزَّقُّومِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":44,"aya_no_marker":"ﰫ","aya_text":"طَعَامُ ٱلۡأَثِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":45,"aya_no_marker":"ﰬ","aya_text":"كَٱلۡمُهۡلِ يَغۡلِي فِي ٱلۡبُطُونِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":46,"aya_no_marker":"ﰭ","aya_text":"كَغَلۡيِ ٱلۡحَمِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":47,"aya_no_marker":"ﰮ","aya_text":"خُذُوهُ فَٱعۡتِلُوهُ إِلَىٰ سَوَآءِ ٱلۡجَحِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":48,"aya_no_marker":"ﰯ","aya_text":"ثُمَّ صُبُّواْ فَوۡقَ رَأۡسِهِۦ مِنۡ عَذَابِ ٱلۡحَمِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":49,"aya_no_marker":"ﰰ","aya_text":"ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِيزُ ٱلۡكَرِيمُ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":50,"aya_no_marker":"ﰱ","aya_text":"إِنَّ هَٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"إِنَّ ٱلۡمُتَّقِينَ فِي مَقَامٍ أَمِينٖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"فِي جَنَّٰتٖ وَعُيُونٖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"يَلۡبَسُونَ مِن سُندُسٖ وَإِسۡتَبۡرَقٖ مُّتَقَٰبِلِينَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"كَذَٰلِكَ وَزَوَّجۡنَٰهُم بِحُورٍ عِينٖ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"يَدۡعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ ءَامِنِينَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"لَا يَذُوقُونَ فِيهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِيمِ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"فَضۡلٗا مِّن رَّبِّكَۚ ذَٰلِكَ هُوَ ٱلۡفَوۡزُ ٱلۡعَظِيمُ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"فَإِنَّمَا يَسَّرۡنَٰهُ بِلِسَانِكَ لَعَلَّهُمۡ يَتَذَكَّرُونَ"},{"jozz":25,"sura_no":44,"sura_name_ar":"الدُّخان","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"فَٱرۡتَقِبۡ إِنَّهُم مُّرۡتَقِبُونَ"}]