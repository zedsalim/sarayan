[{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"فَلَمَّا رَأَوۡهُ زُلۡفَةٗ سِيٓـَٔتۡ وُجُوهُ ٱلَّذِينَ كَفَرُواْ وَقِيلَ هَٰذَا ٱلَّذِي كُنتُم بِهِۦ تَدَّعُونَ"},{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"قُلۡ أَرَءَيۡتُمۡ إِنۡ أَهۡلَكَنِيَ ٱللَّهُ وَمَن مَّعِيَ أَوۡ رَحِمَنَا فَمَن يُجِيرُ ٱلۡكَٰفِرِينَ مِنۡ عَذَابٍ أَلِيمٖ"},{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"قُلۡ هُوَ ٱلرَّحۡمَٰنُ ءَامَنَّا بِهِۦ وَعَلَيۡهِ تَوَكَّلۡنَاۖ فَسَتَعۡلَمُونَ مَنۡ هُوَ فِي ضَلَٰلٖ مُّبِينٖ"},{"jozz":29,"sura_no":67,"sura_name_ar":"المُلك","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"قُلۡ أَرَءَيۡتُمۡ إِنۡ أَصۡبَحَ مَآؤُكُمۡ غَوۡرٗا فَمَن يَأۡتِيكُم بِمَآءٖ مَّعِينِۭ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"نٓۚ وَٱلۡقَلَمِ وَمَا يَسۡطُرُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"مَآ أَنتَ بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونٖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَإِنَّ لَكَ لَأَجۡرًا غَيۡرَ مَمۡنُونٖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"فَسَتُبۡصِرُ وَيُبۡصِرُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"بِأَييِّكُمُ ٱلۡمَفۡتُونُ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعۡلَمُ بِٱلۡمُهۡتَدِينَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"فَلَا تُطِعِ ٱلۡمُكَذِّبِينَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَدُّواْ لَوۡ تُدۡهِنُ فَيُدۡهِنُونَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"وَلَا تُطِعۡ كُلَّ حَلَّافٖ مَّهِينٍ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"هَمَّازٖ مَّشَّآءِۭ بِنَمِيمٖ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"مَّنَّاعٖ لِّلۡخَيۡرِ مُعۡتَدٍ أَثِيمٍ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"عُتُلِّۭ بَعۡدَ ذَٰلِكَ زَنِيمٍ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"أَن كَانَ ذَا مَالٖ وَبَنِينَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"إِذَا تُتۡلَىٰ عَلَيۡهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلۡأَوَّلِينَ"},{"jozz":29,"sura_no":68,"sura_name_ar":"القَلَم","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"سَنَسِمُهُۥ عَلَى ٱلۡخُرۡطُومِ"}]