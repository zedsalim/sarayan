[{"jozz":30,"sura_no":109,"sura_name_ar":"الكافِرون","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"قُلۡ يَٰٓأَيُّهَا ٱلۡكَٰفِرُونَ"},{"jozz":30,"sura_no":109,"sura_name_ar":"الكافِرون","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"لَآ أَعۡبُدُ مَا تَعۡبُدُونَ"},{"jozz":30,"sura_no":109,"sura_name_ar":"الكافِرون","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ"},{"jozz":30,"sura_no":109,"sura_name_ar":"الكافِرون","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ"},{"jozz":30,"sura_no":109,"sura_name_ar":"الكافِرون","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ"},{"jozz":30,"sura_no":109,"sura_name_ar":"الكافِرون","aya_no":6,"aya_no_marker":"ﰅ","aya_text":"لَكُمۡ دِينُكُمۡ وَلِيَ دِينِ"},{"jozz":30,"sura_no":110,"sura_name_ar":"النَّصر","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"إِذَا جَآءَ نَصۡرُ ٱللَّهِ وَٱلۡفَتۡحُ"},{"jozz":30,"sura_no":110,"sura_name_ar":"النَّصر","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَرَأَيۡتَ ٱلنَّاسَ يَدۡخُلُونَ فِي دِينِ ٱللَّهِ أَفۡوَاجٗا"},{"jozz":30,"sura_no":110,"sura_name_ar":"النَّصر","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"فَسَبِّحۡ بِحَمۡدِ رَبِّكَ وَٱسۡتَغۡفِرۡهُۚ إِنَّهُۥ كَانَ تَوَّابَۢا"},{"jozz":30,"sura_no":111,"sura_name_ar":"المَسَد","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"تَبَّتۡ يَدَآ أَبِي لَهَبٖ وَتَبَّ"},{"jozz":30,"sura_no":111,"sura_name_ar":"المَسَد","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"مَآ أَغۡنَىٰ عَنۡهُ مَالُهُۥ وَمَا كَسَبَ"},{"jozz":30,"sura_no":111,"sura_name_ar":"المَسَد","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"سَيَصۡلَىٰ نَارٗا ذَاتَ لَهَبٖ"},{"jozz":30,"sura_no":111,"sura_name_ar":"المَسَد","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَٱمۡرَأَتُهُۥ حَمَّالَةَ ٱلۡحَطَبِ"},{"jozz":30,"sura_no":111,"sura_name_ar":"المَسَد","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"فِي جِيدِهَا حَبۡلٞ مِّن مَّسَدِۭ"}]