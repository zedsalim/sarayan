[{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":207,"aya_no_marker":"ﳎ","aya_text":"مَآ أَغۡنَىٰ عَنۡهُم مَّا كَانُواْ يُمَتَّعُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":208,"aya_no_marker":"ﳏ","aya_text":"وَمَآ أَهۡلَكۡنَا مِن قَرۡيَةٍ إِلَّا لَهَا مُنذِرُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":209,"aya_no_marker":"ﳐ","aya_text":"ذِكۡرَىٰ وَمَا كُنَّا ظَٰلِمِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":210,"aya_no_marker":"ﳑ","aya_text":"وَمَا تَنَزَّلَتۡ بِهِ ٱلشَّيَٰطِينُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":211,"aya_no_marker":"ﳒ","aya_text":"وَمَا يَنۢبَغِي لَهُمۡ وَمَا يَسۡتَطِيعُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":212,"aya_no_marker":"ﳓ","aya_text":"إِنَّهُمۡ عَنِ ٱلسَّمۡعِ لَمَعۡزُولُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":213,"aya_no_marker":"ﳔ","aya_text":"فَلَا تَدۡعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلۡمُعَذَّبِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":214,"aya_no_marker":"ﳕ","aya_text":"وَأَنذِرۡ عَشِيرَتَكَ ٱلۡأَقۡرَبِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":215,"aya_no_marker":"ﳖ","aya_text":"وَٱخۡفِضۡ جَنَاحَكَ لِمَنِ ٱتَّبَعَكَ مِنَ ٱلۡمُؤۡمِنِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":216,"aya_no_marker":"ﳗ","aya_text":"فَإِنۡ عَصَوۡكَ فَقُلۡ إِنِّي بَرِيٓءٞ مِّمَّا تَعۡمَلُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":217,"aya_no_marker":"ﳘ","aya_text":"وَتَوَكَّلۡ عَلَى ٱلۡعَزِيزِ ٱلرَّحِيمِ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":218,"aya_no_marker":"ﳙ","aya_text":"ٱلَّذِي يَرَىٰكَ حِينَ تَقُومُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":219,"aya_no_marker":"ﳚ","aya_text":"وَتَقَلُّبَكَ فِي ٱلسَّٰجِدِينَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":220,"aya_no_marker":"ﳛ","aya_text":"إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلۡعَلِيمُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":221,"aya_no_marker":"ﳜ","aya_text":"هَلۡ أُنَبِّئُكُمۡ عَلَىٰ مَن تَنَزَّلُ ٱلشَّيَٰطِينُ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":222,"aya_no_marker":"ﳝ","aya_text":"تَنَزَّلُ عَلَىٰ كُلِّ أَفَّاكٍ أَثِيمٖ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":223,"aya_no_marker":"ﳞ","aya_text":"يُلۡقُونَ ٱلسَّمۡعَ وَأَكۡثَرُهُمۡ كَٰذِبُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":224,"aya_no_marker":"ﳟ","aya_text":"وَٱلشُّعَرَآءُ يَتَّبِعُهُمُ ٱلۡغَاوُۥنَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":225,"aya_no_marker":"ﳠ","aya_text":"أَلَمۡ تَرَ أَنَّهُمۡ فِي كُلِّ وَادٖ يَهِيمُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":226,"aya_no_marker":"ﳡ","aya_text":"وَأَنَّهُمۡ يَقُولُونَ مَا لَا يَفۡعَلُونَ"},{"jozz":19,"sura_no":26,"sura_name_ar":"الشعراء","aya_no":227,"aya_no_marker":"ﳢ","aya_text":"إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّٰلِحَٰتِ وَذَكَرُواْ ٱللَّهَ كَثِيرٗا وَٱنتَصَرُواْ مِنۢ بَعۡدِ مَا ظُلِمُواْۗ وَسَيَعۡلَمُ ٱلَّذِينَ ظَلَمُوٓاْ أَيَّ مُنقَلَبٖ يَنقَلِبُونَ"}]