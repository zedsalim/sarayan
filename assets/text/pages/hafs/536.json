[{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":51,"aya_no_marker":"ﰲ","aya_text":"ثُمَّ إِنَّكُمۡ أَيُّهَا ٱلضَّآلُّونَ ٱلۡمُكَذِّبُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"لَأٓكِلُونَ مِن شَجَرٖ مِّن زَقُّومٖ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"فَشَٰرِبُونَ عَلَيۡهِ مِنَ ٱلۡحَمِيمِ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"فَشَٰرِبُونَ شُرۡبَ ٱلۡهِيمِ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"هَٰذَا نُزُلُهُمۡ يَوۡمَ ٱلدِّينِ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"نَحۡنُ خَلَقۡنَٰكُمۡ فَلَوۡلَا تُصَدِّقُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"أَفَرَءَيۡتُم مَّا تُمۡنُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"ءَأَنتُمۡ تَخۡلُقُونَهُۥٓ أَمۡ نَحۡنُ ٱلۡخَٰلِقُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"نَحۡنُ قَدَّرۡنَا بَيۡنَكُمُ ٱلۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِينَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":61,"aya_no_marker":"ﰼ","aya_text":"عَلَىٰٓ أَن نُّبَدِّلَ أَمۡثَٰلَكُمۡ وَنُنشِئَكُمۡ فِي مَا لَا تَعۡلَمُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":62,"aya_no_marker":"ﰽ","aya_text":"وَلَقَدۡ عَلِمۡتُمُ ٱلنَّشۡأَةَ ٱلۡأُولَىٰ فَلَوۡلَا تَذَكَّرُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":63,"aya_no_marker":"ﰾ","aya_text":"أَفَرَءَيۡتُم مَّا تَحۡرُثُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":64,"aya_no_marker":"ﰿ","aya_text":"ءَأَنتُمۡ تَزۡرَعُونَهُۥٓ أَمۡ نَحۡنُ ٱلزَّٰرِعُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":65,"aya_no_marker":"ﱀ","aya_text":"لَوۡ نَشَآءُ لَجَعَلۡنَٰهُ حُطَٰمٗا فَظَلۡتُمۡ تَفَكَّهُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":66,"aya_no_marker":"ﱁ","aya_text":"إِنَّا لَمُغۡرَمُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":67,"aya_no_marker":"ﱂ","aya_text":"بَلۡ نَحۡنُ مَحۡرُومُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":68,"aya_no_marker":"ﱃ","aya_text":"أَفَرَءَيۡتُمُ ٱلۡمَآءَ ٱلَّذِي تَشۡرَبُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":69,"aya_no_marker":"ﱄ","aya_text":"ءَأَنتُمۡ أَنزَلۡتُمُوهُ مِنَ ٱلۡمُزۡنِ أَمۡ نَحۡنُ ٱلۡمُنزِلُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":70,"aya_no_marker":"ﱅ","aya_text":"لَوۡ نَشَآءُ جَعَلۡنَٰهُ أُجَاجٗا فَلَوۡلَا تَشۡكُرُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":71,"aya_no_marker":"ﱆ","aya_text":"أَفَرَءَيۡتُمُ ٱلنَّارَ ٱلَّتِي تُورُونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":72,"aya_no_marker":"ﱇ","aya_text":"ءَأَنتُمۡ أَنشَأۡتُمۡ شَجَرَتَهَآ أَمۡ نَحۡنُ ٱلۡمُنشِـُٔونَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":73,"aya_no_marker":"ﱈ","aya_text":"نَحۡنُ جَعَلۡنَٰهَا تَذۡكِرَةٗ وَمَتَٰعٗا لِّلۡمُقۡوِينَ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":74,"aya_no_marker":"ﱉ","aya_text":"فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِيمِ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":75,"aya_no_marker":"ﱊ","aya_text":"۞ فَلَآ أُقۡسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ"},{"jozz":27,"sura_no":56,"sura_name_ar":"الوَاقِعة","aya_no":76,"aya_no_marker":"ﱋ","aya_text":"وَإِنَّهُۥ لَقَسَمٞ لَّوۡ تَعۡلَمُونَ عَظِيمٌ"}]