[{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"وَجَآءَ فِرۡعَوۡنُ وَمَن قَبۡلَهُۥ وَٱلۡمُؤۡتَفِكَٰتُ بِٱلۡخَاطِئَةِ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"فَعَصَوۡاْ رَسُولَ رَبِّهِمۡ فَأَخَذَهُمۡ أَخۡذَةٗ رَّابِيَةً"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"إِنَّا لَمَّا طَغَا ٱلۡمَآءُ حَمَلۡنَٰكُمۡ فِي ٱلۡجَارِيَةِ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"لِنَجۡعَلَهَا لَكُمۡ تَذۡكِرَةٗ وَتَعِيَهَآ أُذُنٞ وَٰعِيَةٞ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"فَإِذَا نُفِخَ فِي ٱلصُّورِ نَفۡخَةٞ وَٰحِدَةٞ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"وَحُمِلَتِ ٱلۡأَرۡضُ وَٱلۡجِبَالُ فَدُكَّتَا دَكَّةٗ وَٰحِدَةٗ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"فَيَوۡمَئِذٖ وَقَعَتِ ٱلۡوَاقِعَةُ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"وَٱنشَقَّتِ ٱلسَّمَآءُ فَهِيَ يَوۡمَئِذٖ وَاهِيَةٞ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"وَٱلۡمَلَكُ عَلَىٰٓ أَرۡجَآئِهَاۚ وَيَحۡمِلُ عَرۡشَ رَبِّكَ فَوۡقَهُمۡ يَوۡمَئِذٖ ثَمَٰنِيَةٞ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"يَوۡمَئِذٖ تُعۡرَضُونَ لَا تَخۡفَىٰ مِنكُمۡ خَافِيَةٞ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"فَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ هَآؤُمُ ٱقۡرَءُواْ كِتَٰبِيَهۡ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"إِنِّي ظَنَنتُ أَنِّي مُلَٰقٍ حِسَابِيَهۡ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"فَهُوَ فِي عِيشَةٖ رَّاضِيَةٖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"فِي جَنَّةٍ عَالِيَةٖ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"قُطُوفُهَا دَانِيَةٞ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"كُلُواْ وَٱشۡرَبُواْ هَنِيٓـَٔۢا بِمَآ أَسۡلَفۡتُمۡ فِي ٱلۡأَيَّامِ ٱلۡخَالِيَةِ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"وَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِشِمَالِهِۦ فَيَقُولُ يَٰلَيۡتَنِي لَمۡ أُوتَ كِتَٰبِيَهۡ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"وَلَمۡ أَدۡرِ مَا حِسَابِيَهۡ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"يَٰلَيۡتَهَا كَانَتِ ٱلۡقَاضِيَةَ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"مَآ أَغۡنَىٰ عَنِّي مَالِيَهۡۜ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"هَلَكَ عَنِّي سُلۡطَٰنِيَهۡ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"خُذُوهُ فَغُلُّوهُ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":31,"aya_no_marker":"ﰞ","aya_text":"ثُمَّ ٱلۡجَحِيمَ صَلُّوهُ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":32,"aya_no_marker":"ﰟ","aya_text":"ثُمَّ فِي سِلۡسِلَةٖ ذَرۡعُهَا سَبۡعُونَ ذِرَاعٗا فَٱسۡلُكُوهُ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":33,"aya_no_marker":"ﰠ","aya_text":"إِنَّهُۥ كَانَ لَا يُؤۡمِنُ بِٱللَّهِ ٱلۡعَظِيمِ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":34,"aya_no_marker":"ﰡ","aya_text":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ"},{"jozz":29,"sura_no":69,"sura_name_ar":"الحَاقة","aya_no":35,"aya_no_marker":"ﰢ","aya_text":"فَلَيۡسَ لَهُ ٱلۡيَوۡمَ هَٰهُنَا حَمِيمٞ"}]