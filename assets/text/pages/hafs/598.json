[{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"أَرَءَيۡتَ إِن كَذَّبَ وَتَوَلَّىٰٓ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"أَلَمۡ يَعۡلَم بِأَنَّ ٱللَّهَ يَرَىٰ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"كَلَّا لَئِن لَّمۡ يَنتَهِ لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"فَلۡيَدۡعُ نَادِيَهُۥ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"سَنَدۡعُ ٱلزَّبَانِيَةَ"},{"jozz":30,"sura_no":96,"sura_name_ar":"العَلَق","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"كَلَّا لَا تُطِعۡهُ وَٱسۡجُدۡۤ وَٱقۡتَرِب۩"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"إِنَّآ أَنزَلۡنَٰهُ فِي لَيۡلَةِ ٱلۡقَدۡرِ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَمَآ أَدۡرَىٰكَ مَا لَيۡلَةُ ٱلۡقَدۡرِ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"لَيۡلَةُ ٱلۡقَدۡرِ خَيۡرٞ مِّنۡ أَلۡفِ شَهۡرٖ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"تَنَزَّلُ ٱلۡمَلَٰٓئِكَةُ وَٱلرُّوحُ فِيهَا بِإِذۡنِ رَبِّهِم مِّن كُلِّ أَمۡرٖ"},{"jozz":30,"sura_no":97,"sura_name_ar":"القَدر","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"سَلَٰمٌ هِيَ حَتَّىٰ مَطۡلَعِ ٱلۡفَجۡرِ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"لَمۡ يَكُنِ ٱلَّذِينَ كَفَرُواْ مِنۡ أَهۡلِ ٱلۡكِتَٰبِ وَٱلۡمُشۡرِكِينَ مُنفَكِّينَ حَتَّىٰ تَأۡتِيَهُمُ ٱلۡبَيِّنَةُ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"رَسُولٞ مِّنَ ٱللَّهِ يَتۡلُواْ صُحُفٗا مُّطَهَّرَةٗ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"فِيهَا كُتُبٞ قَيِّمَةٞ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَمَا تَفَرَّقَ ٱلَّذِينَ أُوتُواْ ٱلۡكِتَٰبَ إِلَّا مِنۢ بَعۡدِ مَا جَآءَتۡهُمُ ٱلۡبَيِّنَةُ"},{"jozz":30,"sura_no":98,"sura_name_ar":"البَينَة","aya_no":5,"aya_no_marker":"ﰄ","aya_text":"وَمَآ أُمِرُوٓاْ إِلَّا لِيَعۡبُدُواْ ٱللَّهَ مُخۡلِصِينَ لَهُ ٱلدِّينَ حُنَفَآءَ وَيُقِيمُواْ ٱلصَّلَوٰةَ وَيُؤۡتُواْ ٱلزَّكَوٰةَۚ وَذَٰلِكَ دِينُ ٱلۡقَيِّمَةِ"}]