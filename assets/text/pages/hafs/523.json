[{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":52,"aya_no_marker":"ﰳ","aya_text":"كَذَٰلِكَ مَآ أَتَى ٱلَّذِينَ مِن قَبۡلِهِم مِّن رَّسُولٍ إِلَّا قَالُواْ سَاحِرٌ أَوۡ مَجۡنُونٌ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":53,"aya_no_marker":"ﰴ","aya_text":"أَتَوَاصَوۡاْ بِهِۦۚ بَلۡ هُمۡ قَوۡمٞ طَاغُونَ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":54,"aya_no_marker":"ﰵ","aya_text":"فَتَوَلَّ عَنۡهُمۡ فَمَآ أَنتَ بِمَلُومٖ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":55,"aya_no_marker":"ﰶ","aya_text":"وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِينَ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":56,"aya_no_marker":"ﰷ","aya_text":"وَمَا خَلَقۡتُ ٱلۡجِنَّ وَٱلۡإِنسَ إِلَّا لِيَعۡبُدُونِ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":57,"aya_no_marker":"ﰸ","aya_text":"مَآ أُرِيدُ مِنۡهُم مِّن رِّزۡقٖ وَمَآ أُرِيدُ أَن يُطۡعِمُونِ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":58,"aya_no_marker":"ﰹ","aya_text":"إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلۡقُوَّةِ ٱلۡمَتِينُ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":59,"aya_no_marker":"ﰺ","aya_text":"فَإِنَّ لِلَّذِينَ ظَلَمُواْ ذَنُوبٗا مِّثۡلَ ذَنُوبِ أَصۡحَٰبِهِمۡ فَلَا يَسۡتَعۡجِلُونِ"},{"jozz":27,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":60,"aya_no_marker":"ﰻ","aya_text":"فَوَيۡلٞ لِّلَّذِينَ كَفَرُواْ مِن يَوۡمِهِمُ ٱلَّذِي يُوعَدُونَ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور","aya_no":1,"aya_no_marker":"ﰀ","aya_text":"وَٱلطُّورِ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور","aya_no":2,"aya_no_marker":"ﰁ","aya_text":"وَكِتَٰبٖ مَّسۡطُورٖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور","aya_no":3,"aya_no_marker":"ﰂ","aya_text":"فِي رَقّٖ مَّنشُورٖ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور","aya_no":4,"aya_no_marker":"ﰃ","aya_text":"وَٱلۡبَيۡتِ ٱلۡمَعۡمُورِ"},{"jozz":27,"sura_no":52,"sura_name_ar":"الطُّور","aya_no":5,"aya_no_marker":"ﰄ","a