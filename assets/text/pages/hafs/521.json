[{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":7,"aya_no_marker":"ﰆ","aya_text":"وَٱلسَّمَآءِ ذَاتِ ٱلۡحُبُكِ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":8,"aya_no_marker":"ﰇ","aya_text":"إِنَّكُمۡ لَفِي قَوۡلٖ مُّخۡتَلِفٖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":9,"aya_no_marker":"ﰈ","aya_text":"يُؤۡفَكُ عَنۡهُ مَنۡ أُفِكَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":10,"aya_no_marker":"ﰉ","aya_text":"قُتِلَ ٱلۡخَرَّٰصُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":11,"aya_no_marker":"ﰊ","aya_text":"ٱلَّذِينَ هُمۡ فِي غَمۡرَةٖ سَاهُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":12,"aya_no_marker":"ﰋ","aya_text":"يَسۡـَٔلُونَ أَيَّانَ يَوۡمُ ٱلدِّينِ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":13,"aya_no_marker":"ﰌ","aya_text":"يَوۡمَ هُمۡ عَلَى ٱلنَّارِ يُفۡتَنُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":14,"aya_no_marker":"ﰍ","aya_text":"ذُوقُواْ فِتۡنَتَكُمۡ هَٰذَا ٱلَّذِي كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":15,"aya_no_marker":"ﰎ","aya_text":"إِنَّ ٱلۡمُتَّقِينَ فِي جَنَّٰتٖ وَعُيُونٍ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":16,"aya_no_marker":"ﰏ","aya_text":"ءَاخِذِينَ مَآ ءَاتَىٰهُمۡ رَبُّهُمۡۚ إِنَّهُمۡ كَانُواْ قَبۡلَ ذَٰلِكَ مُحۡسِنِينَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":17,"aya_no_marker":"ﰐ","aya_text":"كَانُواْ قَلِيلٗا مِّنَ ٱلَّيۡلِ مَا يَهۡجَعُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":18,"aya_no_marker":"ﰑ","aya_text":"وَبِٱلۡأَسۡحَارِ هُمۡ يَسۡتَغۡفِرُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":19,"aya_no_marker":"ﰒ","aya_text":"وَفِيٓ أَمۡوَٰلِهِمۡ حَقّٞ لِّلسَّآئِلِ وَٱلۡمَحۡرُومِ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":20,"aya_no_marker":"ﰓ","aya_text":"وَفِي ٱلۡأَرۡضِ ءَايَٰتٞ لِّلۡمُوقِنِينَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":21,"aya_no_marker":"ﰔ","aya_text":"وَفِيٓ أَنفُسِكُمۡۚ أَفَلَا تُبۡصِرُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":22,"aya_no_marker":"ﰕ","aya_text":"وَفِي ٱلسَّمَآءِ رِزۡقُكُمۡ وَمَا تُوعَدُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":23,"aya_no_marker":"ﰖ","aya_text":"فَوَرَبِّ ٱلسَّمَآءِ وَٱلۡأَرۡضِ إِنَّهُۥ لَحَقّٞ مِّثۡلَ مَآ أَنَّكُمۡ تَنطِقُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":24,"aya_no_marker":"ﰗ","aya_text":"هَلۡ أَتَىٰكَ حَدِيثُ ضَيۡفِ إِبۡرَٰهِيمَ ٱلۡمُكۡرَمِينَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":25,"aya_no_marker":"ﰘ","aya_text":"إِذۡ دَخَلُواْ عَلَيۡهِ فَقَالُواْ سَلَٰمٗاۖ قَالَ سَلَٰمٞ قَوۡمٞ مُّنكَرُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":26,"aya_no_marker":"ﰙ","aya_text":"فَرَاغَ إِلَىٰٓ أَهۡلِهِۦ فَجَآءَ بِعِجۡلٖ سَمِينٖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":27,"aya_no_marker":"ﰚ","aya_text":"فَقَرَّبَهُۥٓ إِلَيۡهِمۡ قَالَ أَلَا تَأۡكُلُونَ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":28,"aya_no_marker":"ﰛ","aya_text":"فَأَوۡجَسَ مِنۡهُمۡ خِيفَةٗۖ قَالُواْ لَا تَخَفۡۖ وَبَشَّرُوهُ بِغُلَٰمٍ عَلِيمٖ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":29,"aya_no_marker":"ﰜ","aya_text":"فَأَقۡبَلَتِ ٱمۡرَأَتُهُۥ فِي صَرَّةٖ فَصَكَّتۡ وَجۡهَهَا وَقَالَتۡ عَجُوزٌ عَقِيمٞ"},{"jozz":26,"sura_no":51,"sura_name_ar":"الذَّاريَات","aya_no":30,"aya_no_marker":"ﰝ","aya_text":"قَالُواْ كَذَٰلِكِ قَالَ رَبُّكِۖ إِنَّهُۥ هُوَ ٱلۡحَكِيمُ ٱلۡعَلِيمُ"}]